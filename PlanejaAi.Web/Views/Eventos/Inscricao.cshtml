@model PlanejaAi.Models.Convidado
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Confirmar Presença - @ViewBag.EventoNome</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />

    <style>
            :root {
                --cor-escura: #213448;
                --cor-media: #547792;
                --cor-clara: #94B4C1;
                --cor-bege: #EAE0CF;
            }

            body {
                background-color: var(--cor-bege);
                color: var(--cor-escura);
                font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            }

            .card-convidado {
                background-color: #ffffff;
                border-radius: 16px;
                border: none;
                box-shadow: 0 12px 32px rgba(33, 52, 72, 0.15);
            }

            .texto-destaque {
                color: var(--cor-media);
            }

            .btn-planeja {
                background-color: var(--cor-media);
                color: white;
                border: none;
                font-weight: 600;
                transition: all 0.3s ease;
            }

                .btn-planeja:hover {
                    background-color: var(--cor-escura);
                    color: white;
                }

            .form-control:focus, .form-select:focus {
                border-color: var(--cor-media);
                box-shadow: 0 0 0 0.25rem rgba(84, 119, 146, 0.25);
            }
    </style>
</head>
<body>
    <div class="container mt-5 mb-5">
        <div class="row justify-content-center">
            <div class="col-md-8 col-lg-6">
                <div class="card card-convidado p-4 p-md-5">

                    <div class="text-center mb-4">
                        <div class="mb-3">
                            <i class="fa-regular fa-calendar-check fa-3x texto-destaque"></i>
                        </div>
                        <h3 class="fw-bold texto-destaque">@ViewBag.EventoNome</h3>
                        <p class="text-muted">Ficamos felizes com a sua presença! Preencha os dados abaixo para nos enviar sua resposta.</p>
                    </div>

                    <form asp-action="ConfirmarPresenca" method="post" novalidate id="formInscricao">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="EventoId" value="@ViewBag.EventoId" />

                        <div class="mb-3">
                            <label class="form-label fw-bold">Nome do Convidado <span class="text-danger">*</span></label>
                            <input type="text" name="Nome" class="form-control form-control-lg" required autocomplete="off" placeholder="Digite seu nome completo" />
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-bold">Status de Confirmação <span class="text-danger">*</span></label>
                            <select name="Confirmacao" class="form-select form-select-lg" required>
                                <option value="" disabled selected>Selecione uma opção...</option>
                                <option value="1">Confirmado</option>
                                <option value="2">Em Dúvida</option>
                                <option value="0">Não Confirmado</option>
                            </select>
                        </div>

                        <button type="submit" class="btn btn-planeja w-100 py-3 rounded-3 fs-5 mt-2">
                            <i class="fa-solid fa-paper-plane me-2"></i> Enviar Resposta
                        </button>
                    </form>

                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        document.getElementById('formInscricao').addEventListener('submit', function (e) {
        const inputNome = this.querySelector('input[name="Nome"]');
        const selectStatus = this.querySelector('select[name="Confirmacao"]');

        if (!inputNome.value.trim() || !selectStatus.value) {
        e.preventDefault();
        Swal.fire({
        title: 'Atenção!',
        text: 'Por favor, preencha seu nome e selecione o status de confirmação.',
        icon: 'warning',
        confirmButtonColor: '#547792'
        });
        }
        });
    </script>

    @if (TempData["SucessoInscricao"] != null)
    {
        <script>
            Swal.fire({
            title: 'Resposta Registrada!',
            html: '@Html.Raw(TempData["SucessoInscricao"])',
            icon: 'success',
            confirmButtonColor: '#4b7d62'
            }).then(() => {
            document.getElementById('formInscricao').reset();
            });
        </script>
    }
</body>
</html>
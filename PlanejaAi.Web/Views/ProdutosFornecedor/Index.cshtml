@model IEnumerable<PlanejaAi.Models.ProdutoFornecedor>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<style>
    :root {
    --cor-escura: #213448;
    --cor-media: #547792;
    --cor-clara: #94B4C1;
    --cor-bege: #EAE0CF;
    }

    body {
    background-color: var(--cor-bege) !important;
    color: var(--cor-escura);
    transition: background-color 0.3s ease, color 0.3s ease;
    }

    [data-theme="dark"] body {
    background-color: var(--cor-escura) !important;
    color: var(--cor-bege);
    }

    .card-planeja {
    background-color: #ffffff;
    border-radius: 12px;
    border: none;
    box-shadow: 0 8px 24px rgba(0,0,0,0.1);
    padding: 20px;
    }

    [data-theme="dark"] .card-planeja {
    background-color: var(--cor-media) !important;
    }

    .search-container .form-control {
    background-color: rgba(255, 255, 255, 0.5);
    border: 1px solid var(--cor-media);
    color: var(--cor-escura) !important;
    }

    [data-theme="dark"] .search-container .form-control {
    background-color: var(--cor-escura) !important;
    color: #ffffff !important;
    }

    .thead-planeja th {
    color: var(--cor-media) !important;
    font-weight: 700;
    text-transform: uppercase;
    font-size: 0.85rem;
    }

    .table tbody td {
    color: #000000 !important;
    }

    [data-theme="dark"] .thead-planeja th {
    color: var(--cor-bege) !important;
    }

    [data-theme="dark"] .table tbody td {
    color: #ffffff !important;
    }

    [data-theme="dark"] .table tbody td .text-muted {
    color: var(--cor-clara) !important;
    }

    .thead-planeja {
    background-color: rgba(33, 52, 72, 0.05);
    }

    .btn-planeja-primary {
    background-color: var(--cor-media);
    color: white;
    border: none;
    font-weight: bold;
    transition: all 0.3s ease;
    }

    .btn-planeja-primary:hover {
    background-color: var(--cor-escura);
    color: white;
    }

    [data-theme="dark"] .btn-planeja-primary {
    background-color: var(--cor-clara);
    color: var(--cor-escura);
    }

    [data-theme="dark"] .btn-planeja-primary:hover {
    background-color: #ffffff;
    color: var(--cor-escura);
    }

    .texto-identificador-empresa {
    color: var(--cor-media);
    font-weight: 600;
    transition: color 0.3s ease;
    }

    [data-theme="dark"] .texto-identificador-empresa {
    color: var(--cor-clara) !important;
    }

    .texto-valor-produto {
    color: var(--cor-media);
    transition: color 0.3s ease;
    }

    [data-theme="dark"] .texto-valor-produto {
    color: var(--cor-bege) !important;
    }

    .filtro-badge {
    background-color: var(--cor-media);
    color: white;
    font-size: 0.85rem;
    padding: 5px 12px;
    border-radius: 20px;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    box-shadow: 0 2px 5px rgba(0,0,0,0.1);
    transition: all 0.3s ease;
    }

    .filtro-badge a {
    color: white;
    opacity: 0.7;
    transition: opacity 0.2s, transform 0.2s;
    display: flex;
    align-items: center;
    }

    .filtro-badge a:hover {
    opacity: 1;
    transform: scale(1.1);
    }

    [data-theme="dark"] .filtro-badge {
    background-color: var(--cor-clara);
    color: var(--cor-escura);
    }

    [data-theme="dark"] .filtro-badge a {
    color: var(--cor-escura);
    }

    .search-container .form-select {
    background-color: rgba(255, 255, 255, 0.5);
    border: 1px solid var(--cor-media);
    color: var(--cor-escura) !important;
    font-weight: 500;
    }

    [data-theme="dark"] .search-container .form-select {
    background-color: var(--cor-escura) !important;
    color: #ffffff !important;
    }

    [data-theme="dark"] .modal-content p,
    [data-theme="dark"] .modal-content label,
    [data-theme="dark"] .modal-content h5 {
    color: #ffffff !important;
    }

    [data-theme="dark"] .modal-content .text-muted {
    color: rgba(255, 255, 255, 0.75) !important;
    }

    [data-theme="dark"] .btn-close {
    filter: invert(1) grayscale(1) brightness(2);
    }

    .input-link {
    background-color: #f8f9fa !important;
    color: var(--cor-escura) !important;
    border: 1px solid #dee2e6;
    }

    [data-theme="dark"] .input-link {
    background-color: var(--cor-escura) !important;
    color: #ffffff !important;
    border: 1px solid rgba(255, 255, 255, 0.2) !important;
    }

    [data-theme="dark"] .input-link::-webkit-file-upload-button {
    background-color: #f8f9fa !important;
    color: var(--cor-escura) !important;
    border: none !important;
    border-right: 1px solid rgba(255, 255, 255, 0.2) !important;
    transition: background-color 0.2s ease;
    }

    [data-theme="dark"] .input-link::file-selector-button {
    background-color: #f8f9fa !important;
    color: var(--cor-escura) !important;
    border: none !important;
    border-right: 1px solid rgba(255, 255, 255, 0.2) !important;
    transition: background-color 0.2s ease;
    }

    [data-theme="dark"] .input-link:hover::-webkit-file-upload-button,
    [data-theme="dark"] .input-link:hover::file-selector-button {
    background-color: #ced4da !important;
    cursor: pointer;
    }

    [data-theme="dark"] .modal-content .btn-outline-secondary {
    border: 1px solid var(--cor-bege) !important;
    color: var(--cor-bege) !important;
    background-color: transparent !important;
    transition: all 0.3s ease;
    }

    [data-theme="dark"] .modal-content .btn-outline-secondary:hover {
    background-color: var(--cor-bege) !important;
    color: #000000 !important;
    border-color: var(--cor-bege) !important;
    }
</style>

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="m-0 fw-bold" style="color: var(--cor-media);">Catálogo de Produtos</h2>

            @if (ViewBag.FornecedorId != null)
            {
                <div class="mt-2 filtro-badge">
                    <span><i class="fa-solid fa-filter me-1"></i> Fornecedor: <strong>@ViewBag.FornecedorNome</strong></span>
                    <a asp-action="Index" title="Remover filtro e ver todos">
                        <i class="fa-solid fa-circle-xmark fs-5"></i>
                    </a>
                </div>
            }
            else
            {
                <p class="text-muted m-0 mt-1">Gerencie os produtos cadastrados no sistema</p>
            }
        </div>
        <div class="d-flex flex-wrap gap-2">
            <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary btn-sm px-3 shadow-sm">
                <i class="fa-solid fa-house me-2"></i>Início
            </a>

            <a asp-controller="Fornecedores" asp-action="Index" class="btn btn-outline-secondary btn-sm px-3 shadow-sm">
                <i class="fa-solid fa-truck-fast me-2"></i>Fornecedores
            </a>

            <a asp-controller="CategoriasServico" asp-action="Index" class="btn btn-outline-secondary btn-sm px-3 shadow-sm">
                <i class="fa-solid fa-tags me-2"></i>Categorias
            </a>

            @if (User.IsInRole("admin") || User.IsInRole("owner"))
            {
                <a asp-action="ExportarCsv" asp-route-fornecedorId="@ViewBag.FornecedorId" class="btn btn-outline-secondary btn-sm px-3 shadow-sm" title="Exportar para Excel">
                    <i class="fa-solid fa-file-export me-1"></i> Exportar
                </a>

                <button type="button" class="btn btn-outline-secondary btn-sm px-3 shadow-sm" data-bs-toggle="modal" data-bs-target="#modalImportarCsv">
                    <i class="fa-solid fa-file-import me-1"></i> Importar
                </button>
            }

            <a asp-action="Criar" asp-route-fornecedorId="@ViewBag.FornecedorId" class="btn btn-planeja-primary btn-sm px-3 shadow-sm">
                <i class="fa-solid fa-plus me-2"></i>Novo Produto
            </a>
        </div>
    </div>

    <div class="mb-4 search-container">
        <form asp-action="Index" method="get" class="d-flex flex-wrap gap-2" onsubmit="return false;">

            <div class="shadow-sm" style="min-width: 250px;">
                <select name="fornecedorId" asp-items="ViewBag.ListaFornecedores" class="form-select h-100" onchange="this.form.submit()">
                    <option value="">Todos os Fornecedores</option>
                </select>
            </div>

            <div class="input-group shadow-sm" style="max-width: 450px;">
                <span class="input-group-text border-0" style="background-color: var(--cor-media); color: white;">
                    <i class="fa-solid fa-magnifying-glass"></i>
                </span>
                <input type="text" id="inputBusca" class="form-control" placeholder="Buscar produto, fornecedor ou empresa...">
            </div>
            <button type="button" id="btnPesquisar" class="btn btn-planeja-primary px-4 shadow-sm">Pesquisar</button>
        </form>
    </div>

    <div class="card-planeja shadow-sm">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="thead-planeja">
                    <tr>
                        <th class="ps-4 border-0">Produto / Serviço</th>
                        <th class="border-0">Categoria</th>
                        <th class="border-0">Valor Padrão</th>
                        <th class="border-0">Status</th>
                        <th class="text-end pe-4 border-0">Ações</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="5" class="text-center py-5 text-muted fst-italic">Nenhum produto encontrado.</td>
                        </tr>
                    }
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-4">
                                <div class="fw-bold">@item.Nome</div>
                                <div class="text-muted small text-truncate" style="max-width: 250px;" title="@item.Descricao">
                                    @(string.IsNullOrEmpty(item.Descricao) ? "Sem descrição" : item.Descricao)
                                </div>

                                @if (User.IsInRole("owner"))
                                {
                                    <div class="small mt-2 texto-identificador-empresa">
                                        <i class="fa-solid fa-building me-1"></i> Empresa: @(item.Fornecedor?.Empresa?.Nome ?? "Não informada")
                                    </div>
                                    <div class="small texto-identificador-empresa" style="opacity: 0.85;">
                                        <i class="fa-solid fa-truck-fast me-1"></i> Fornecedor: @(item.Fornecedor?.Nome ?? "Não informado")
                                    </div>
                                }
                            </td>
                            <td>
                                <span class="badge bg-secondary">@(item.Categoria?.Nome ?? "Sem categoria")</span>
                            </td>
                            <td>
                                <div class="fw-bold texto-valor-produto">
                                    @item.ValorPadrao.GetValueOrDefault().ToString("C", new System.Globalization.CultureInfo("pt-BR"))
                                </div>
                                <small class="text-muted">Unid: @(item.Unidade ?? "-")</small>
                            </td>
                            <td>
                                @if (item.Ativo)
                                {
                                    <span class="badge bg-success">Ativo</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">Inativo</span>
                                }
                            </td>
                            <td class="text-end pe-4">
                                <div class="d-flex justify-content-end gap-2">
                                    <a asp-action="Editar" asp-route-id="@item.Id" asp-route-fornecedorOrigem="@ViewBag.FornecedorId" class="btn btn-sm text-info" title="Editar">
                                        <i class="fa-solid fa-pen"></i>
                                    </a>

                                    @if (User.IsInRole("admin") || User.IsInRole("owner"))
                                    {
                                        <form asp-action="Deletar"
                                              asp-route-id="@item.Id"
                                              asp-route-fornecedorId="@item.FornecedorId"
                                              asp-route-fornecedorOrigem="@ViewBag.FornecedorId"
                                              method="post"
                                              class="d-inline form-excluir">

                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm text-danger btn-excluir" data-nome="@item.Nome" title="Excluir">
                                                <i class="fa-solid fa-trash"></i>
                                            </button>
                                        </form>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="modalImportarCsv" tabindex="-1" aria-labelledby="modalImportarCsvLabel" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content card-planeja">
            <form id="formImportarCsv" asp-action="ImportarCsv" method="post" enctype="multipart/form-data" novalidate>
                @Html.AntiForgeryToken()

                @if (ViewBag.FornecedorId != null)
                {
                    <input type="hidden" name="fornecedorId" value="@ViewBag.FornecedorId" />
                }

                <div class="modal-header border-0">
                    <h5 class="modal-title fw-bold" id="modalImportarCsvLabel" style="color: var(--cor-media);">
                        <i class="fa-solid fa-file-import me-2"></i> Importar Produtos
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <p class="text-muted small mb-1">
                        Suba um arquivo <strong>.csv</strong> contendo a lista. O formato ideal tem colunas separadas por ponto e vírgula (;).<br><br>
                        <strong>Coluna 1:</strong> Nome do produto (Obrigatório)<br>
                        <strong>Coluna 2:</strong> Descrição<br>
                        <strong>Coluna 3:</strong> Valor Padrão<br>
                        <strong>Coluna 4:</strong> Unidade (Ex: Un, Kg, Lt)<br>
                        <strong>Coluna 5:</strong> Categoria (Obrigatório - Deve existir no sistema)<br>
                        <strong>Coluna 6:</strong> Fornecedor (Obrigatório - Deve existir no sistema)
                    </p>

                    <div>
                        <label for="arquivoCsv" class="form-label fw-bold mt-2">Arquivo CSV</label>
                        <input class="form-control input-link" type="file" id="arquivoCsv" name="arquivoCsv" accept=".csv">
                    </div>
                </div>
                <div class="modal-footer border-0">
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancelar</button>
                    <button type="submit" class="btn btn-planeja-primary fw-normal">Importar Agora</button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    document.addEventListener("DOMContentLoaded", function() {
    const isDark = document.documentElement.getAttribute('data-theme') === 'dark';

    const erroMsg = @Html.Raw(Json.Serialize(TempData["Erro"]));
    const sucessoMsg = @Html.Raw(Json.Serialize(TempData["Sucesso"]));

    if (erroMsg && erroMsg !== "") {
    Swal.fire({
    icon: 'error',
    title: 'Ops!',
    text: erroMsg,
    background: isDark ? '#213448' : '#ffffff',
    color: isDark ? '#EAE0CF' : '#213448',
    confirmButtonColor: '#547792'
    });
    }

    if (sucessoMsg && sucessoMsg !== "") {
    Swal.fire({
    icon: 'success',
    title: 'Sucesso!',
    text: sucessoMsg,
    background: isDark ? '#213448' : '#ffffff',
    color: isDark ? '#EAE0CF' : '#213448',
    confirmButtonColor: '#547792'
    });
    }
    });
    document.querySelectorAll('.form-excluir').forEach(form => {
    form.addEventListener('submit', function (e) {
    e.preventDefault();
    const btn = this.querySelector('.btn-excluir');
    const nome = btn.getAttribute('data-nome');
    const isDark = document.documentElement.getAttribute('data-theme') === 'dark';

    Swal.fire({
    title: 'Excluir Produto?',
    text: `Deseja remover o produto/serviço "${nome}"?`,
    icon: 'warning',
    showCancelButton: true,
    background: isDark ? '#213448' : '#ffffff',
    color: isDark ? '#EAE0CF' : '#213448',
    confirmButtonColor: '#dc3545',
    cancelButtonColor: '#547792',
    confirmButtonText: 'Sim, excluir',
    cancelButtonText: 'Cancelar'
    }).then((result) => {
    if (result.isConfirmed) { HTMLFormElement.prototype.submit.call(this); }
    });
    });
    });

    function aplicarFiltro() {
    let textoBusca = document.getElementById('inputBusca').value.toLowerCase();
    let linhasTabela = document.querySelectorAll('.table tbody tr');

    linhasTabela.forEach(function (linha) {
    let primeiraCelula = linha.querySelector('td');
    if (primeiraCelula && primeiraCelula.getAttribute('colspan')) return;

    let textoDaLinha = linha.textContent.toLowerCase();
    linha.style.display = textoDaLinha.includes(textoBusca) ? '' : 'none';
    });
    }

    document.getElementById('inputBusca').addEventListener('keyup', aplicarFiltro);
    document.getElementById('btnPesquisar').addEventListener('click', aplicarFiltro);

    document.getElementById('formImportarCsv')?.addEventListener('submit', function (e) {
    const fileInput = document.getElementById('arquivoCsv');
    const isDarkTheme = document.documentElement.getAttribute('data-theme') === 'dark';

    if (!fileInput.value) {
    e.preventDefault();
    Swal.fire({
    title: 'Arquivo ausente!',
    text: 'Por favor, selecione um arquivo .csv válido antes de clicar em importar.',
    icon: 'warning',
    background: isDarkTheme ? '#213448' : '#ffffff',
    color: isDarkTheme ? '#EAE0CF' : '#213448',
    confirmButtonColor: '#547792',
    scrollbarPadding: false
    });
    return;
    }

    const fileName = fileInput.value.toLowerCase();
    if (!fileName.endsWith('.csv')) {
    e.preventDefault();
    fileInput.value = '';
    Swal.fire({
    title: 'Formato Inválido!',
    text: 'Você só pode importar planilhas no formato .CSV. Por favor, salve seu arquivo como CSV e tente novamente.',
    icon: 'error',
    background: isDarkTheme ? '#213448' : '#ffffff',
    color: isDarkTheme ? '#EAE0CF' : '#213448',
    confirmButtonColor: '#547792',
    scrollbarPadding: false
    });
    }
    });
</script>
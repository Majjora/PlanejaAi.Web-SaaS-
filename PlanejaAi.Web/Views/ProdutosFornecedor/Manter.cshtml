@model PlanejaAi.Models.ProdutoFornecedor

@{
    bool isEdicao = Model.Id > 0;
    ViewData["Title"] = isEdicao ? "Editar Produto" : "Novo Produto";
}

<style>
    :root {
        --cor-escura: #213448;
        --cor-media: #547792;
        --cor-clara: #94B4C1;
        --cor-bege: #EAE0CF;
    }

    body {
        background-color: var(--cor-bege) !important;
        color: var(--cor-escura);
        transition: all 0.3s ease;
    }

    [data-theme="dark"] body {
        background-color: var(--cor-escura) !important;
        color: var(--cor-bege);
    }

    .card-planeja {
        background-color: #ffffff;
        border-radius: 12px;
        border: none;
        box-shadow: 0 8px 24px rgba(0,0,0,0.1);
        padding: 30px;
    }

    [data-theme="dark"] .card-planeja {
        background-color: var(--cor-media) !important;
        color: #ffffff;
    }

    .form-control, .form-select {
        border-color: var(--cor-clara);
    }

        .form-control:focus, .form-select:focus {
            border-color: var(--cor-media);
            box-shadow: 0 0 0 0.2rem rgba(84, 119, 146, 0.25);
        }

    [data-theme="dark"] .form-control, [data-theme="dark"] .form-select {
        background-color: var(--cor-escura);
        color: #fff;
        border-color: rgba(255,255,255,0.1);
    }

    .btn-planeja-primary {
        background-color: var(--cor-media);
        color: white;
        border: none;
        font-weight: bold;
    }

        .btn-planeja-primary:hover {
            background-color: var(--cor-escura);
            color: white;
            transform: translateY(-2px);
        }

    [data-theme="dark"] .btn-planeja-primary {
        background-color: var(--cor-clara);
        color: var(--cor-escura);
    }

        [data-theme="dark"] .btn-planeja-primary:hover {
            background-color: #ffffff;
            color: var(--cor-escura);
        }
</style>

<div class="container mt-5" style="max-width: 800px;">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="m-0 fw-bold" style="color: var(--cor-media);">
                @(isEdicao ? "Editar Produto/Serviço" : "Novo Produto/Serviço")
            </h2>
            <p class="text-muted small">Preencha os dados abaixo para o catálogo do fornecedor.</p>
        </div>

        @{
            var fornecedorOrigem = Context.Request.Query["fornecedorId"].ToString();
        }
        <a asp-action="Index" asp-route-fornecedorId="@fornecedorOrigem" class="btn btn-outline-secondary px-3 shadow-sm">
            <i class="fa-solid fa-chevron-left me-2"></i>Voltar
        </a>
    </div>

    <div class="card-planeja shadow-sm">
        <form asp-action="@(isEdicao ? "Editar" : "Criar")" asp-route-fornecedorOrigem="@fornecedorOrigem" method="post" novalidate>
            @if (isEdicao)
            {
                <input type="hidden" asp-for="Id" />
            }
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="row g-3">

                <div class="col-md-12 mb-2">
                    <label asp-for="FornecedorId" class="form-label fw-bold">Fornecedor *</label>
                    <select asp-for="FornecedorId" class="form-select" asp-items="ViewBag.Fornecedores" required>
                        <option value="">-- Selecione o Fornecedor --</option>
                    </select>
                    <span asp-validation-for="FornecedorId" class="text-danger small"></span>
                </div>

                <div class="col-md-8">
                    <label asp-for="Nome" class="form-label fw-bold">Nome do Produto/Serviço *</label>
                    <input asp-for="Nome" class="form-control" placeholder="Ex: Buffet Completo" required />
                    <span asp-validation-for="Nome" class="text-danger small"></span>
                </div>

                <div class="col-md-4">
                    <label asp-for="CategoriaId" class="form-label fw-bold">Categoria *</label>
                    <select asp-for="CategoriaId" class="form-select" asp-items="ViewBag.Categorias" required>
                        <option value="">-- Selecione --</option>
                    </select>
                    <span asp-validation-for="CategoriaId" class="text-danger small"></span>
                </div>

                <div class="col-md-12">
                    <label asp-for="Descricao" class="form-label fw-bold">Descrição</label>
                    <textarea asp-for="Descricao" class="form-control" rows="3" placeholder="Detalhes técnicos, o que inclui, etc..."></textarea>
                    <span asp-validation-for="Descricao" class="text-danger small"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="ValorPadrao" class="form-label fw-bold">Valor Padrão (R$) *</label>
                    <input asp-for="ValorPadrao" type="text" class="form-control" placeholder="0,00" required />
                    <span asp-validation-for="ValorPadrao" class="text-danger small"></span>
                </div>

                <div class="col-md-6">
                    <label asp-for="Unidade" class="form-label fw-bold">Unidade de Medida</label>
                    <input asp-for="Unidade" class="form-control" placeholder="Ex: Diária, Pessoa, Unidade" />
                    <span asp-validation-for="Unidade" class="text-danger small"></span>
                </div>

                <div class="col-md-12 mt-4">
                    <div class="form-check form-switch fs-5">
                        <input class="form-check-input" type="checkbox" asp-for="Ativo" id="switchAtivo">
                        <label class="form-check-label fs-6 ms-2 mt-1" for="switchAtivo">Disponível no catálogo</label>
                    </div>
                </div>
            </div>

            <hr class="my-4" style="border-color: var(--cor-clara); opacity: 0.2;" />

            <div class="d-grid gap-2 d-md-flex justify-content-md-end">
                <button type="submit" class="btn btn-planeja-primary px-5 py-2 shadow-sm">
                    <i class="fa-solid fa-save me-2"></i>
                    @(isEdicao ? "Atualizar Alterações" : "Salvar Produto")
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const inputValor = document.getElementById('ValorPadrao');
            
            if(inputValor) {
                inputValor.addEventListener('input', function (e) {
                    let valor = e.target.value.replace(/\D/g, '');
                    
                    if (valor === "") {
                        e.target.value = "";
                        return;
                    }

                    valor = (parseInt(valor, 10) / 100).toFixed(2);
                    
                    valor = valor.replace('.', ',');
                    
                    valor = valor.replace(/(\d)(?=(\d{3})+(?!\d))/g, '$1.');
                    
                    e.target.value = valor;
                });
            }
        });

        $.validator.methods.range = function (value, element, param) {
            var globalizedValue = value.replace(".", "");
            globalizedValue = globalizedValue.replace(",", ".");
            return this.optional(element) || (globalizedValue >= param[0] && globalizedValue <= param[1]);
        };
        
        $.validator.methods.number = function (value, element) {
            return this.optional(element) || /^-?(?:\d+|\d{1,3}(?:[\s\.,]\d{3})+)(?:[\.,]\d+)?$/.test(value);
        };
    </script>
}
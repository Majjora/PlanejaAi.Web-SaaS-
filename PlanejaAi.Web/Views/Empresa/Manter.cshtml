@model PlanejaAi.Models.Empresa

@{
    ViewData["Title"] = Model.Id == 0 ? "Nova Empresa" : "Editar Empresa";
}

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<style>
    :root {
        --cor-escura: #213448;
        --cor-media: #547792;
        --cor-clara: #94B4C1;
        --cor-bege: #EAE0CF;
    }

    
    body {
        background-color: var(--cor-bege) !important;
        color: var(--cor-escura);
        transition: all 0.3s ease;
    }

    [data-theme="dark"] body {
        background-color: var(--cor-escura) !important;
        color: var(--cor-bege);
    }

    
    .card-planeja {
        background-color: #ffffff;
        border-radius: 12px;
        border: none;
        box-shadow: 0 8px 24px rgba(0,0,0,0.1);
        padding: 30px;
        transition: all 0.3s ease;
    }

    [data-theme="dark"] .card-planeja {
        background-color: var(--cor-media) !important;
        box-shadow: 0 8px 24px rgba(0,0,0,0.3);
    }

    
    .form-label {
        color: var(--cor-media);
        font-weight: 700;
        margin-bottom: 0.4rem;
    }

    [data-theme="dark"] .form-label {
        color: var(--cor-bege);
    }

    .form-control, .form-select {
        background-color: rgba(255, 255, 255, 0.8);
        border: 1px solid var(--cor-clara);
        color: var(--cor-escura) !important;
    }

    [data-theme="dark"] .form-control,
    [data-theme="dark"] .form-select {
        background-color: var(--cor-escura) !important;
        color: #ffffff !important;
        border-color: var(--cor-clara);
    }

    
    .main-title {
        color: var(--cor-media);
        transition: color 0.3s ease;
    }

    [data-theme="dark"] .main-title {
        color: var(--cor-bege) !important; 
    }

    .section-title {
        color: var(--cor-media);
        font-size: 0.85rem;
        letter-spacing: 1px;
        margin-top: 2rem;
        transition: color 0.3s ease;
    }

    [data-theme="dark"] .section-title {
        color: var(--cor-bege) !important; 
    }

    [data-theme="dark"] hr {
        border-color: var(--cor-bege);
        opacity: 0.2;
    }

    
    .btn-planeja-primary {
        background-color: var(--cor-media);
        color: white;
        border: none;
        font-weight: bold;
    }

    [data-theme="dark"] .btn-planeja-primary {
        background-color: var(--cor-clara);
        color: var(--cor-escura);
    }

    .btn-planeja-outline {
        border: 2px solid var(--cor-media);
        color: var(--cor-media);
        font-weight: bold;
    }

    [data-theme="dark"] .btn-planeja-outline {
        border-color: var(--cor-bege);
        color: var(--cor-bege);
    }

    
    .btn-planeja-primary, .btn-planeja-outline {
        transition: all 0.3s ease;
    }

        
        .btn-planeja-primary:hover {
            background-color: var(--cor-escura); 
            color: white;
        }

        .btn-planeja-outline:hover {
            background-color: var(--cor-media); 
            color: white;
        }

    
    [data-theme="dark"] .btn-planeja-primary:hover {
        background-color: #ffffff; 
        color: var(--cor-escura);
    }

    [data-theme="dark"] .btn-planeja-outline:hover {
        background-color: var(--cor-bege); 
        color: var(--cor-escura);
    }
</style>

<div class="container mt-5 mb-5">
    <div class="card-planeja">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="m-0 fw-bold main-title">@ViewData["Title"]</h2>
        </div>

        @if (ViewBag.Erro != null)
        {
            <div class="alert alert-danger border-0 shadow-sm">@ViewBag.Erro</div>
        }

        <form asp-action="Manter" method="post" class="needs-validation" novalidate>
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />

            <div class="row g-3">
                
                <div class="col-md-6">
                    <label class="form-label">Nome da Empresa*</label>
                    <input asp-for="Nome" class="form-control" placeholder="Ex: Planeja Ai LTDA" required />
                    <div class="invalid-feedback">O nome da empresa é obrigatório.</div>
                </div>
                <div class="col-md-6">
                    <label class="form-label">CPF ou CNPJ*</label>
                    <input asp-for="CpfCnpj" id="doc" class="form-control" maxlength="14" required
                           onblur="validarEDispararBusca(this.value)"
                           oninput="this.value = this.value.replace(/[^0-9]/g, '')" autocomplete="off" />
                    <div class="invalid-feedback">Informe um CPF ou CNPJ válido.</div>
                </div>

                <div class="col-md-4">
                    <label class="form-label">E-mail*</label>
                    <input asp-for="Email" type="email" class="form-control" required autocomplete="off" />
                    <div class="invalid-feedback">Informe um e-mail válido.</div>
                </div>
                <div class="col-md-4">
                    <label class="form-label">Telefone*</label>
                    <input asp-for="Telefone" class="form-control" maxlength="11" required
                           oninput="this.value = this.value.replace(/[^0-9]/g, '')" />
                    <div class="invalid-feedback">O telefone é obrigatório.</div>
                </div>
                <div class="col-md-4">
                    <label class="form-label">Status*</label>
                    <select asp-for="Status" class="form-select" required>
                        <option value="Ativa">Ativa</option>
                        <option value="Inativa">Inativa</option>
                        <option value="Suspensa">Suspensa</option>
                    </select>
                </div>

                <div class="col-12">
                    <h5 class="section-title text-uppercase fw-bold">Endereço</h5>
                    <hr style="opacity: 0.1;" class="mt-1" />
                </div>

                
                <div class="col-md-3">
                    <label class="form-label">CEP*</label>
                    <input asp-for="Cep" id="cep" class="form-control" maxlength="8" required
                           onblur="buscarCep(this.value)" oninput="this.value = this.value.replace(/[^0-9]/g, '')" />
                </div>
                <div class="col-md-7">
                    <label class="form-label">Logradouro*</label>
                    <input asp-for="Endereco" id="logradouro" class="form-control" required />
                </div>
                <div class="col-md-2">
                    <label class="form-label">Nº*</label>
                    <input asp-for="Numero" id="numero" class="form-control" required
                           oninput="this.value = this.value.replace(/[^0-9]/g, '')" />
                </div>

                <div class="col-md-5">
                    <label class="form-label">Bairro*</label>
                    <input asp-for="Bairro" id="bairro" class="form-control" required />
                </div>
                <div class="col-md-5">
                    <label class="form-label">Cidade*</label>
                    <input asp-for="Cidade" id="cidade" class="form-control" required />
                </div>
                <div class="col-md-2">
                    <label class="form-label">UF*</label>
                    <select asp-for="Estado" id="uf" class="form-select" required>
                        <option value="">--</option>
                        <option value="AC">AC</option>
                        <option value="AL">AL</option>
                        <option value="AP">AP</option>
                        <option value="AM">AM</option>
                        <option value="BA">BA</option>
                        <option value="CE">CE</option>
                        <option value="DF">DF</option>
                        <option value="ES">ES</option>
                        <option value="GO">GO</option>
                        <option value="MA">MA</option>
                        <option value="MT">MT</option>
                        <option value="MS">MS</option>
                        <option value="MG">MG</option>
                        <option value="PA">PA</option>
                        <option value="PB">PB</option>
                        <option value="PR">PR</option>
                        <option value="PE">PE</option>
                        <option value="PI">PI</option>
                        <option value="RJ">RJ</option>
                        <option value="RN">RN</option>
                        <option value="RS">RS</option>
                        <option value="RO">RO</option>
                        <option value="RR">RR</option>
                        <option value="SC">SC</option>
                        <option value="SP">SP</option>
                        <option value="SE">SE</option>
                        <option value="TO">TO</option>
                    </select>
                </div>
            </div>

            <div class="mt-5 d-flex gap-2">
                <button type="submit" class="btn btn-planeja-primary px-5 py-2 shadow-sm">
                    <i class="fa-solid fa-save me-2"></i>Salvar
                </button>
                <a asp-action="Cadastro" class="btn btn-planeja-outline px-4 py-2">
                    <i class="fa-solid fa-xmark me-2"></i>Cancelar
                </a>
            </div>
        </form>
    </div>
</div>

<script>
    (function () {
        'use strict'
        var forms = document.querySelectorAll('.needs-validation')
        Array.prototype.slice.call(forms).forEach(function (form) {
            form.addEventListener('submit', function (event) {
                if (!form.checkValidity()) {
                    event.preventDefault()
                    event.stopPropagation()
                }
                form.classList.add('was-validated')
            }, false)
        })
    })()

    function validarEDispararBusca(valor) {
    var doc = valor.replace(/\D/g, '');
    if (doc.length === 14) {
    buscarCnpj(doc);
    }
    }

    function buscarCep(valor) {
        var cep = valor.replace(/\D/g, '');
        if (cep != "" && cep.length === 8) {
            const isDark = document.documentElement.getAttribute('data-theme') === 'dark';
            fetch(`https://viacep.com.br/ws/${cep}/json/`)
                .then(response => response.json())
                .then(dados => {
                    if (!("erro" in dados)) {
                        document.getElementById('logradouro').value = dados.logradouro;
                        document.getElementById('bairro').value = dados.bairro;
                        document.getElementById('cidade').value = dados.localidade;
                        document.getElementById('uf').value = dados.uf;
                        document.getElementById('numero').focus();
                    } else {
                        Swal.fire({
                            icon: 'error',
                            title: 'CEP não encontrado',
                            background: isDark ? '#213448' : '#ffffff',
                            color: isDark ? '#EAE0CF' : '#213448',
                            confirmButtonColor: '#547792'
                        });
                    }
                });
        }
    }

            function buscarCnpj(valor) {
        
        var cnpj = valor.replace(/\D/g, '');

        
        if (cnpj !== "" && cnpj.length === 14) {
            const isDark = document.documentElement.getAttribute('data-theme') === 'dark';

            fetch(`https://brasilapi.com.br/api/cnpj/v1/${cnpj}`)
                .then(response => {
                    if (!response.ok) {
                        throw new Error('CNPJ não encontrado');
                    }
                    return response.json();
                })
                .then(dados => {
                    
                    if (document.getElementById('Nome')) {
                        document.getElementById('Nome').value = dados.razao_social || '';
                    }

                    
                    if (document.getElementById('Email') && dados.email) {
                        document.getElementById('Email').value = dados.email;
                    }

                    
                    if (document.getElementById('Telefone') && dados.ddd_telefone_1) {
                        document.getElementById('Telefone').value = dados.ddd_telefone_1.replace(/\D/g, '');
                    }

                    
                    if (dados.cep && document.getElementById('cep')) {
                        document.getElementById('cep').value = dados.cep;
                        buscarCep(dados.cep);
                    }
                })
                .catch(error => {
                    Swal.fire({
                        icon: 'error',
                        title: 'CNPJ inválido ou não encontrado',
                        text: 'Verifique o número e tente novamente.',
                        background: isDark ? '#213448' : '#ffffff',
                        color: isDark ? '#EAE0CF' : '#213448',
                        confirmButtonColor: '#547792'
                    });
                });
        }
    }



</script>


@model IEnumerable<PlanejaAi.Models.Empresa>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<link rel="stylesheet" href="https://code.jquery.com/ui/1.13.2/themes/base/jquery-ui.css">

<style>
    :root {
        --cor-escura: #213448;
        --cor-media: #547792;
        --cor-clara: #94B4C1;
        --cor-bege: #EAE0CF;
    }

    
    body {
        background-color: var(--cor-bege) !important;
        color: var(--cor-escura);
        transition: all 0.3s ease;
    }

    [data-theme="dark"] body {
        background-color: var(--cor-escura) !important;
        color: var(--cor-bege);
    }

    
    .card-planeja {
        background-color: #ffffff;
        border-radius: 12px;
        border: none;
        box-shadow: 0 8px 24px rgba(0,0,0,0.1);
        padding: 20px;
    }

    [data-theme="dark"] .card-planeja {
        background-color: var(--cor-media) !important;
    }

    
    .search-container .form-control {
        background-color: rgba(255, 255, 255, 0.5);
        border: 1px solid var(--cor-media);
        color: var(--cor-escura) !important;
    }

    [data-theme="dark"] .search-container .form-control {
        background-color: var(--cor-escura) !important;
        color: #ffffff !important;
    }

    

    
    .thead-planeja th {
        color: var(--cor-media) !important;
        font-weight: 700;
        text-transform: uppercase;
        font-size: 0.85rem;
    }

    
    .table tbody td {
        color: #000000 !important;
    }

    
    [data-theme="dark"] .thead-planeja th {
        color: var(--cor-bege) !important;
    }

    [data-theme="dark"] .table tbody td {
        color: #ffffff !important;
    }

    .thead-planeja {
        background-color: rgba(33, 52, 72, 0.05);
    }

    
    .btn-planeja-primary {
        background-color: var(--cor-media);
        color: white;
        border: none;
        font-weight: bold;
        
        transition: all 0.3s ease;
    }

        
        .btn-planeja-primary:hover {
            background-color: var(--cor-escura);
            color: white;
            transform: translateY(-2px); 
            box-shadow: 0 6px 15px rgba(0, 0, 0, 0.2) !important;
        }

    
    [data-theme="dark"] .btn-planeja-primary {
        background-color: var(--cor-clara);
        color: var(--cor-escura);
    }

        
        [data-theme="dark"] .btn-planeja-primary:hover {
            background-color: #ffffff; 
            color: var(--cor-escura);
            transform: translateY(-2px); 
            
            box-shadow: 0 6px 15px rgba(0, 0, 0, 0.5) !important;
        }
</style>

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="m-0 fw-bold" style="color: var(--cor-media);">Gestão de Empresas</h2>
            <p class="text-muted m-0">Administre os registros cadastrados</p>
        </div>
        <div class="d-flex gap-2">
            <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary btn-sm px-3 shadow-sm">
                <i class="fa-solid fa-house me-2"></i>Início
            </a>
            <a asp-action="Manter" class="btn btn-planeja-primary btn-sm px-3 shadow-sm">
                <i class="fa-solid fa-plus me-2"></i>Nova Empresa
            </a>
        </div>
    </div>

    <div class="mb-4 search-container">
        <form asp-action="Cadastro" method="get" class="d-flex gap-2" onsubmit="return false;">
            <div class="input-group shadow-sm" style="max-width: 450px;">
                <span class="input-group-text border-0" style="background-color: var(--cor-media); color: white;">
                    <i class="fa-solid fa-magnifying-glass"></i>
                </span>
                <input type="text" id="inputBuscaEmpresa" name="busca" class="form-control"
                       placeholder="Buscar empresa por nome, CPF ou CNPJ..."
                       value="@ViewData["FiltroAtual"]">
            </div>
            <button type="button" id="btnPesquisarEmpresa" class="btn btn-planeja-primary px-4 shadow-sm">Pesquisar</button>
        </form>
    </div>

    <div class="card-planeja shadow-sm">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="thead-planeja">
                    <tr>
                        <th class="ps-4 border-0">Nome</th>
                        <th class="border-0">CPF / CNPJ</th>
                        <th class="border-0">Telefone</th>
                        <th class="text-center border-0">Status</th>
                        <th class="text-end pe-4 border-0">Ações</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="5" class="text-center py-5 text-muted italic">Nenhuma empresa encontrada.</td>
                        </tr>
                    }
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-4 fw-bold">@item.Nome</td>
                            <td>@item.CpfCnpj</td>
                            <td>@item.Telefone</td>
                            <td class="text-center">
                                <span class="badge @(item.Status == "Ativa" ? "bg-success" : "bg-danger")">@item.Status</span>
                            </td>
                            <td class="text-end pe-4">
                                <a asp-action="Detalhes" asp-route-id="@item.Id" class="btn btn-sm text-primary" title="Visualizar">
                                    <i class="fa-solid fa-eye"></i>
                                </a>
                                <a asp-action="Manter" asp-route-id="@item.Id" class="btn btn-sm text-info"><i class="fa-solid fa-pen"></i></a>
                                <form asp-action="Deletar" asp-route-id="@item.Id" method="post" class="d-inline form-excluir">
                                    <button type="button" class="btn btn-sm text-danger btn-excluir" data-nome="@item.Nome">
                                        <i class="fa-solid fa-trash"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

<script>

    @if (TempData["Erro"] != null)
    {
            <text>
            document.addEventListener("DOMContentLoaded", function() {
                const isDark = document.documentElement.getAttribute('data-theme') === 'dark';
                Swal.fire({
                    icon: 'error',
                    title: 'Atenção!',
                    text: '@Html.Raw(TempData["Erro"])',
                    background: isDark ? '#213448' : '#ffffff',
                    color: isDark ? '#EAE0CF' : '#213448',
                    confirmButtonColor: '#dc3545'
                });
            });
            </text>
    }

    @if (TempData["Sucesso"] != null)
    {
            <text>
            document.addEventListener("DOMContentLoaded", function() {
                const isDark = document.documentElement.getAttribute('data-theme') === 'dark';
                Swal.fire({
                    icon: 'success',
                    title: 'Sucesso!',
                    text: '@Html.Raw(TempData["Sucesso"])',
                    background: isDark ? '#213448' : '#ffffff',
                    color: isDark ? '#EAE0CF' : '#213448',
                    confirmButtonColor: '#547792'
                });
            });
            </text>
    }


    function aplicarFiltroEmpresas() {
        let textoBusca = document.getElementById('inputBuscaEmpresa').value.toLowerCase();
        let linhasTabela = document.querySelectorAll('.table tbody tr');

        linhasTabela.forEach(function (linha) {
            let primeiraCelula = linha.querySelector('td');
            if (primeiraCelula && primeiraCelula.getAttribute('colspan')) return;

            let textoDaLinha = linha.textContent.toLowerCase();

            if (textoDaLinha.includes(textoBusca)) {
                linha.style.display = '';
            } else {
                linha.style.display = 'none';
            }
        });
    }

    
    document.getElementById('inputBuscaEmpresa').addEventListener('keyup', aplicarFiltroEmpresas);

    
    document.getElementById('btnPesquisarEmpresa').addEventListener('click', aplicarFiltroEmpresas);



    
    document.querySelectorAll('.btn-excluir').forEach(button => {
        button.addEventListener('click', function () {
            const form = this.closest('.form-excluir');
            const nome = this.getAttribute('data-nome');
            const isDark = document.documentElement.getAttribute('data-theme') === 'dark';

            Swal.fire({
                title: 'Excluir?',
                text: `Deseja remover o usuário ${nome}?`,
                icon: 'warning',
                showCancelButton: true, 
                background: isDark ? '#213448' : '#ffffff',
                color: isDark ? '#EAE0CF' : '#213448',
                confirmButtonColor: '#dc3545',
                cancelButtonColor: '#547792',
                confirmButtonText: 'Sim, excluir',
                cancelButtonText: 'Cancelar'
            }).then((result) => {
                if (result.isConfirmed) {
                    form.submit();
                }
            });
        });
    });
</script>


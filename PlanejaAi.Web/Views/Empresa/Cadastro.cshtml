@model IEnumerable<PlanejaAi.Models.Empresa>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<link rel="stylesheet" href="https://code.jquery.com/ui/1.13.2/themes/base/jquery-ui.css">

<style>
    :root {
        --cor-escura: #213448;
        --cor-media: #547792;
        --cor-clara: #94B4C1;
        --cor-bege: #EAE0CF;
    }

    /* 1. FUNDO DA PÁGINA */
    body {
        background-color: var(--cor-bege) !important;
        color: var(--cor-escura);
        transition: all 0.3s ease;
    }

    [data-theme="dark"] body {
        background-color: var(--cor-escura) !important;
        color: var(--cor-bege);
    }

    /* 2. CARD DA TABELA */
    .card-planeja {
        background-color: #ffffff;
        border-radius: 12px;
        border: none;
        box-shadow: 0 8px 24px rgba(0,0,0,0.1);
        padding: 20px;
    }

    [data-theme="dark"] .card-planeja {
        background-color: var(--cor-media) !important;
    }

    /* 3. INPUT DE BUSCA */
    .search-container .form-control {
        background-color: rgba(255, 255, 255, 0.5);
        border: 1px solid var(--cor-media);
        color: var(--cor-escura) !important;
    }

    [data-theme="dark"] .search-container .form-control {
        background-color: var(--cor-escura) !important;
        color: #ffffff !important;
    }

    /* 4. TABELA - ONDE ESTAVA O ERRO */

    /* TOPO DA TABELA (NOME, CNPJ, ETC) - Fica Azul Médio no modo claro */
    .thead-planeja th {
        color: var(--cor-media) !important;
        font-weight: 700;
        text-transform: uppercase;
        font-size: 0.85rem;
    }

    /* DADOS DA TABELA (PLANEJA AI EVENTOS, ETC) - Volta a ser PRETO no modo claro */
    .table tbody td {
        color: #000000 !important;
    }

    /* AJUSTES PARA MODO ESCURO */
    [data-theme="dark"] .thead-planeja th {
        color: var(--cor-bege) !important;
    }

    [data-theme="dark"] .table tbody td {
        color: #ffffff !important;
    }

    .thead-planeja {
        background-color: rgba(33, 52, 72, 0.05);
    }

    /* 5. BOTÕES */
    .btn-planeja-primary {
        background-color: var(--cor-media);
        color: white;
        border: none;
        font-weight: bold;
    }

    [data-theme="dark"] .btn-planeja-primary {
        background-color: var(--cor-clara);
        color: var(--cor-escura);
    }
</style>

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="m-0 fw-bold" style="color: var(--cor-media);">Gestão de Empresas</h2>
            <p class="text-muted m-0">Administre os registros cadastrados</p>
        </div>
        <div class="d-flex gap-2">
            <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary btn-sm px-3 shadow-sm">
                <i class="fa-solid fa-house me-2"></i>Início
            </a>
            <a asp-action="Manter" class="btn btn-planeja-primary btn-sm px-3 shadow-sm">
                <i class="fa-solid fa-plus me-2"></i>Nova Empresa
            </a>
        </div>
    </div>

    <div class="mb-4 search-container">
        <form asp-action="Cadastro" method="get" class="d-flex gap-2">
            <div class="input-group shadow-sm" style="max-width: 450px;">
                <span class="input-group-text border-0" style="background-color: var(--cor-media); color: white;">
                    <i class="fa-solid fa-magnifying-glass"></i>
                </span>
                <input type="text" id="inputBusca" name="busca" class="form-control"
                       placeholder="Buscar por nome ou CNPJ..."
                       value="@ViewData["FiltroAtual"]">
            </div>
            <button type="submit" class="btn btn-planeja-primary px-4 shadow-sm">Pesquisar</button>
        </form>
    </div>

    <div class="card-planeja shadow-sm">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="thead-planeja">
                    <tr>
                        <th class="ps-4 border-0">Nome</th>
                        <th class="border-0">CNPJ</th>
                        <th class="border-0">Telefone</th>
                        <th class="text-center border-0">Status</th>
                        <th class="text-end pe-4 border-0">Ações</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="5" class="text-center py-5 text-muted italic">Nenhuma empresa encontrada.</td>
                        </tr>
                    }
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-4 fw-bold">@item.Nome</td>
                            <td>@item.Cnpj</td>
                            <td>@item.Telefone</td>
                            <td class="text-center">
                                <span class="badge @(item.Status == "Ativa" ? "bg-success" : "bg-danger")">@item.Status</span>
                            </td>
                            <td class="text-end pe-4">
                                <a asp-action="Manter" asp-route-id="@item.Id" class="btn btn-sm text-info"><i class="fa-solid fa-pen"></i></a>
                                <form asp-action="Deletar" asp-route-id="@item.Id" method="post" class="d-inline form-excluir">
                                    <button type="button" class="btn btn-sm text-danger btn-excluir" data-nome="@item.Nome">
                                        <i class="fa-solid fa-trash"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<script>
    document.querySelectorAll('.btn-excluir').forEach(button => {
        button.addEventListener('click', function () {
            const form = this.closest('.form-excluir');
            const nome = this.getAttribute('data-nome');
            const isDark = document.documentElement.getAttribute('data-theme') === 'dark';

            Swal.fire({
                title: 'Excluir?',
                text: `Deseja remover a empresa ${nome}?`,
                icon: 'warning',
                background: isDark ? '#213448' : '#ffffff',
                color: isDark ? '#EAE0CF' : '#213448',
                confirmButtonColor: '#dc3545',
                cancelButtonColor: '#547792',
                confirmButtonText: 'Sim, excluir',
                cancelButtonText: 'Cancelar'
            }).then((result) => { if (result.isConfirmed) form.submit(); });
        });
    });
</script>
@model PlanejaAi.Models.DashboardViewModel
@{
    ViewData["Title"] = "Dashboard Geral";
}

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<style>
    :root {
    --cor-escura: #213448;
    --cor-media: #547792;
    --cor-clara: #94B4C1;
    --cor-bege: #EAE0CF;
    --bg-body: var(--cor-bege);
    --text-main: var(--cor-escura);
    --bg-card: #ffffff;
    --text-muted: var(--cor-media);
    }

    [data-theme="dark"] {
    --bg-body: var(--cor-escura);
    --text-main: var(--cor-bege);
    --bg-card: var(--cor-media);
    --text-muted: var(--cor-clara);
    }

    body {
    background-color: var(--bg-body) !important;
    color: var(--text-main);
    transition: all 0.3s ease;
    font-family: 'Segoe UI', sans-serif;
    }

    .dashboard-container {
    padding: 30px 15px;
    max-width: 1200px;
    margin: 0 auto;
    }

    .card-planeja {
    background-color: var(--bg-card);
    border-radius: 12px;
    border: none;
    box-shadow: 0 8px 24px rgba(0,0,0,0.1);
    padding: 20px;
    transition: all 0.3s ease;
    height: 100%;
    }

    [data-theme="dark"] .card-planeja {
    box-shadow: 0 10px 30px rgba(0,0,0,0.3);
    }

    .titulo-card {
    color: var(--cor-media);
    }

    [data-theme="dark"] .titulo-card {
    color: var(--cor-bege) !important;
    }

    .search-container .form-control {
    background-color: rgba(255, 255, 255, 0.5);
    border: 1px solid var(--cor-media);
    color: var(--cor-escura) !important;
    }

    [data-theme="dark"] .search-container .form-control {
    background-color: var(--cor-escura) !important;
    color: #ffffff !important;
    }

    [data-theme="dark"] input[type="date"]::-webkit-calendar-picker-indicator {
    filter: invert(1);
    }

    .btn-planeja-primary {
    background-color: var(--cor-media);
    color: white;
    border: none;
    font-weight: bold;
    transition: all 0.3s ease;
    }

    .btn-planeja-primary:hover {
    background-color: var(--cor-escura);
    color: white;
    }

    [data-theme="dark"] .btn-planeja-primary {
    background-color: var(--cor-clara);
    color: var(--cor-escura);
    }

    [data-theme="dark"] .btn-planeja-primary:hover {
    background-color: #ffffff;
    color: var(--cor-escura);
    }

    .card-metric {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 15px;
    }

    .metric-info h6 {
    color: var(--text-muted);
    font-size: 0.85rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin-bottom: 0.5rem;
    }

    .metric-info h3 {
    color: var(--text-main);
    font-size: 1.6rem;
    font-weight: 700;
    margin: 0;
    word-break: break-word;
    }

    .metric-icon {
    flex-shrink: 0;
    width: 60px;
    height: 60px;
    background-color: rgba(148, 180, 193, 0.2);
    border-radius: 15px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.8rem;
    color: var(--cor-media);
    }

    [data-theme="dark"] .metric-icon {
    color: var(--cor-bege);
    }

    .lucro-positivo {
    color: #28a745 !important;
    }

    .lucro-negativo {
    color: #dc3545 !important;
    }

    [data-theme="dark"] .lucro-positivo {
    color: #5ce681 !important;
    }

    [data-theme="dark"] .lucro-negativo {
    color: #ff6b6b !important;
    }

    .table {
    color: var(--text-main);
    margin-bottom: 0;
    }

    .table thead th {
    border-bottom: 2px solid var(--cor-clara);
    color: var(--text-muted);
    font-weight: 600;
    text-transform: uppercase;
    font-size: 0.85rem;
    }

    .table tbody td {
    border-bottom: 1px solid rgba(148, 180, 193, 0.2);
    }

    [data-theme="dark"] .table tbody td {
    color: #ffffff !important;
    }

    [data-theme="dark"] .table tbody td .text-muted {
    color: var(--cor-clara) !important;
    }
</style>

<div class="dashboard-container">

    <div class="d-flex justify-content-between align-items-center mb-4 ps-2">
        <div>
            <h2 class="m-0 fw-bold" style="color: var(--cor-media);">
                <i class="fa-solid fa-chart-pie me-2"></i> Visão Geral do Negócio
            </h2>
            <p class="text-muted m-0">Acompanhe seus resultados financeiros e planeje seus próximos eventos.</p>
        </div>

        <div class="d-flex flex-wrap gap-2 pe-1">
            <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary btn-sm px-3 shadow-sm">
                <i class="fa-solid fa-house me-2"></i> Início
            </a>

            <button type="button" onclick="exportarDashboard()" class="btn btn-outline-secondary btn-sm px-3 shadow-sm" title="Exportar para CSV">
                <i class="fa-solid fa-file-export me-1"></i> Exportar
            </button>
        </div>
    </div>

    <div class="mb-4 search-container">
        <form id="formFiltroDashboard" asp-action="Index" method="get" class="d-flex flex-wrap gap-2 align-items-center">

            <div class="input-group shadow-sm" style="max-width: 200px;">
                <span class="input-group-text border-0" style="background-color: var(--cor-media); color: white;" title="Data Inicial">
                    <i class="fa-regular fa-calendar"></i>
                </span>
                <input type="date" name="dataInicio" id="inputDataInicio" class="form-control" value="@ViewData["DataInicioAtual"]" required>
            </div>

            <div class="input-group shadow-sm" style="max-width: 200px;">
                <span class="input-group-text border-0" style="background-color: var(--cor-media); color: white;" title="Data Final">
                    <i class="fa-regular fa-calendar-check"></i>
                </span>
                <input type="date" name="dataFim" id="inputDataFim" class="form-control" value="@ViewData["DataFimAtual"]" required>
            </div>

            <button type="submit" class="btn btn-planeja-primary px-4 shadow-sm">Filtrar</button>

            <a asp-action="Index" class="btn btn-outline-secondary px-3 shadow-sm" title="Limpar Filtros">
                <i class="fa-solid fa-eraser"></i>
            </a>
        </form>
    </div>

    <div class="row row-cols-1 row-cols-md-2 row-cols-xl-4 g-4 mb-4">
        <div class="col">
            <div class="card-planeja card-metric shadow-sm hover-elevate">
                <div class="metric-info">
                    <h6>Eventos Ativos</h6>
                    <h3>@Model.TotalEventosAtivos</h3>
                </div>
                <div class="metric-icon"><i class="fa-solid fa-calendar-days"></i></div>
            </div>
        </div>
        <div class="col">
            <div class="card-planeja card-metric shadow-sm hover-elevate">
                <div class="metric-info">
                    <h6>Concluídos (Período)</h6>
                    <h3>@Model.TotalEventosConcluidos</h3>
                </div>
                <div class="metric-icon"><i class="fa-solid fa-check-double"></i></div>
            </div>
        </div>
        <div class="col">
            <div class="card-planeja card-metric shadow-sm hover-elevate">
                <div class="metric-info">
                    <h6>Faturamento Bruto</h6>
                    <h3>@Model.FaturamentoTotal.ToString("C", new System.Globalization.CultureInfo("pt-BR"))</h3>
                </div>
                <div class="metric-icon"><i class="fa-solid fa-hand-holding-dollar"></i></div>
            </div>
        </div>
        <div class="col">
            <div class="card-planeja card-metric shadow-sm hover-elevate">
                <div class="metric-info">
                    <h6>Lucro Estimado</h6>
                    @{
                        var classeLucro = Model.LucroEstimado >= 0 ? "lucro-positivo" : "lucro-negativo";
                    }
                    <h3 class="@classeLucro">@Model.LucroEstimado.ToString("C", new System.Globalization.CultureInfo("pt-BR"))</h3>
                </div>
                <div class="metric-icon"><i class="fa-solid fa-wallet"></i></div>
            </div>
        </div>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-lg-8">
            <div class="card-planeja h-100 p-4">
                <h5 class="fw-bold mb-4 titulo-card">
                    <i class="fa-solid fa-chart-area me-2"></i> Faturamento vs Custos
                </h5>
                <canvas id="financeiroChart" height="100"></canvas>
            </div>
        </div>

        <div class="col-lg-4">
            <div class="card-planeja h-100 p-4">
                <h5 class="fw-bold mb-3 titulo-card">
                    <i class="fa-solid fa-clock-rotate-left me-2"></i> Próximos Eventos
                </h5>

                @if (Model.ProximosEventos != null && Model.ProximosEventos.Any())
                {
                    <div class="table-responsive">
                        <table class="table align-middle table-hover">
                            <thead>
                                <tr>
                                    <th>Evento & Data</th>
                                    <th class="text-end">Status</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var ev in Model.ProximosEventos)
                                {
                                    <tr>
                                        <td>
                                            <div class="text-truncate fw-bold" style="max-width: 150px;" title="@ev.Nome">
                                                @ev.Nome
                                            </div>
                                            <small class="text-muted"><i class="fa-regular fa-calendar me-1"></i> @ev.Data.ToString("dd/MM/yyyy")</small>
                                        </td>
                                        <td class="text-end" style="width: 1%;">
                                            <span class="badge bg-light text-dark border shadow-sm text-uppercase" style="font-size: 0.7rem; font-weight: 700;">@ev.StatusExibicao</span>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="text-center text-muted p-5 rounded-4" style="background-color: rgba(148, 180, 193, 0.05); border: 2px dashed var(--cor-clara);">
                        <i class="fa-regular fa-calendar-xmark fs-1 mb-3 opacity-50" style="color: var(--cor-media);"></i>
                        <p class="mb-0 fw-bold">Nenhum evento agendado para os próximos dias.</p>
                        <p class="text-sm">Os próximos 5 eventos futuros aparecerão aqui.</p>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        document.addEventListener("DOMContentLoaded", function() {
        const isDarkInitial = document.documentElement.getAttribute('data-theme') === 'dark';
        const erroMsg = '@Html.Raw(TempData["Erro"])';
        const sucessoMsg = '@Html.Raw(TempData["Sucesso"])';

        if (erroMsg) {
        Swal.fire({ icon: 'error', title: 'Ops!', text: erroMsg, background: isDarkInitial ? '#213448' : '#ffffff', color: isDarkInitial ? '#EAE0CF' : '#213448', confirmButtonColor: '#547792', customClass: { popup: 'rounded-4' } });
        }
        if (sucessoMsg) {
        Swal.fire({ icon: 'success', title: 'Sucesso!', text: sucessoMsg, background: isDarkInitial ? '#213448' : '#ffffff', color: isDarkInitial ? '#EAE0CF' : '#213448', confirmButtonColor: '#547792', customClass: { popup: 'rounded-4' } });
        }

        var faturamentoData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.FaturamentoMensal));
        var custoData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.CustoMensal));
        var ctx = document.getElementById('financeiroChart').getContext('2d');

        var labelsGrafico = [];
        const dataInicioStr = document.getElementById('inputDataInicio').value;
        const dataFimStr = document.getElementById('inputDataFim').value;

        if (dataInicioStr && dataFimStr) {
        let dIni = new Date(dataInicioStr + 'T00:00:00');
        let dFim = new Date(dataFimStr + 'T00:00:00');

        const diffTempo = dFim - dIni;
        const diffDias = Math.floor(diffTempo / (1000 * 60 * 60 * 24));

        const mesesAbrev = ['Jan', 'Fev', 'Mar', 'Abr', 'Mai', 'Jun', 'Jul', 'Ago', 'Set', 'Out', 'Nov', 'Dez'];

        if (diffDias === 0) {
        for (let h = 0; h < 24; h++) {
        labelsGrafico.push(`${h.toString().padStart(2, '0')}:00`);
        }
        }
        else if (diffDias <= 31) {
        let atual = new Date(dIni);
        while (atual <= dFim) {
        let dia = atual.getDate().toString().padStart(2, '0');
        let mes = mesesAbrev[atual.getMonth()];
        labelsGrafico.push(`${dia}/${mes}`);
        atual.setDate(atual.getDate() + 1);
        }
        }
        else {
        let atual = new Date(dIni.getFullYear(), dIni.getMonth(), 1);
        let fim = new Date(dFim.getFullYear(), dFim.getMonth(), 1);
        let seguranca = 0;
        while (atual <= fim && seguranca < 13) {
        let nomeMes = mesesAbrev[atual.getMonth()];
        let anoDigitos = atual.getFullYear().toString().substring(2);
        labelsGrafico.push(`${nomeMes}/${anoDigitos}`);
        atual.setMonth(atual.getMonth() + 1);
        seguranca++;
        }
        }
        }

        if (labelsGrafico.length === 0) {
        labelsGrafico = ['Jan', 'Fev', 'Mar', 'Abr', 'Mai', 'Jun', 'Jul', 'Ago', 'Set', 'Out', 'Nov', 'Dez'];
        }

        var financeiroChart = new Chart(ctx, {
        type: 'bar',
        data: {
        labels: labelsGrafico,
        datasets: [
        { label: 'Faturamento', data: faturamentoData, borderRadius: 6, borderWidth: 0 },
        { label: 'Custos', data: custoData, borderRadius: 6, borderWidth: 0 }
        ]
        },
        options: {
        responsive: true,
        maintainAspectRatio: true,
        plugins: {
        legend: { labels: { font: { weight: 'bold', family: "'Segoe UI', sans-serif" } } }
        },
        scales: {
        y: { beginAtZero: true, grid: {}, ticks: { font: { family: "'Segoe UI', sans-serif" } } },
        x: { grid: { display: false }, ticks: { font: { family: "'Segoe UI', sans-serif" } } }
        }
        }
        });

        function aplicarTemaNoGrafico() {
        const isDark = document.documentElement.getAttribute('data-theme') === 'dark' || document.body.getAttribute('data-theme') === 'dark';
        var gridColor = isDark ? 'rgba(234, 224, 207, 0.1)' : 'rgba(33, 52, 72, 0.1)';
        var fontColor = isDark ? '#EAE0CF' : '#213448';
        var corFaturamento = isDark ? '#94B4C1' : '#213448';
        var corCusto = isDark ? '#ff6b6b' : '#dc3545';

        financeiroChart.data.datasets[0].backgroundColor = corFaturamento;
        financeiroChart.data.datasets[1].backgroundColor = corCusto;
        financeiroChart.options.scales.y.grid.color = gridColor;
        financeiroChart.options.scales.y.ticks.color = fontColor;
        financeiroChart.options.scales.x.ticks.color = fontColor;
        financeiroChart.options.plugins.legend.labels.color = fontColor;
        financeiroChart.update();
        }

        aplicarTemaNoGrafico();

        const observer = new MutationObserver(function(mutations) {
        mutations.forEach(function(mutation) {
        if (mutation.attributeName === "data-theme") { aplicarTemaNoGrafico(); }
        });
        });
        observer.observe(document.documentElement, { attributes: true });
        observer.observe(document.body, { attributes: true });

        document.getElementById('formFiltroDashboard').addEventListener('submit', function(e) {
        const dataInicio = document.getElementById('inputDataInicio').value;
        const dataFim = document.getElementById('inputDataFim').value;
        const isDark = document.documentElement.getAttribute('data-theme') === 'dark';

        if (dataInicio && dataFim) {
        const d1 = new Date(dataInicio + 'T00:00:00');
        const d2 = new Date(dataFim + 'T00:00:00');

        if (d1 > d2) {
        e.preventDefault();
        Swal.fire({ icon: 'error', title: 'Intervalo inválido!', text: 'A Data Inicial não pode ser maior que a Data Final.', background: isDark ? '#213448' : '#ffffff', color: isDark ? '#EAE0CF' : '#213448', confirmButtonColor: '#547792', customClass: { popup: 'rounded-4' } });
        return;
        }

        const limiteFiltro = new Date(d1.getTime());
        limiteFiltro.setFullYear(limiteFiltro.getFullYear() + 1);

        if (d2 > limiteFiltro) {
        e.preventDefault();
        Swal.fire({ icon: 'warning', title: 'Período muito longo!', text: 'Para manter a clareza do dashboard, filtre um intervalo de no máximo 1 ano.', background: isDark ? '#213448' : '#ffffff', color: isDark ? '#EAE0CF' : '#213448', confirmButtonColor: '#547792', customClass: { popup: 'rounded-4' } });
        }
        }
        });
        });

        function exportarDashboard() {
        const dataInicio = document.getElementById('inputDataInicio').value;
        const dataFim = document.getElementById('inputDataFim').value;
        const isDark = document.documentElement.getAttribute('data-theme') === 'dark';

        if (!dataInicio || !dataFim) {
        Swal.fire({ icon: 'warning', title: 'Datas obrigatórias!', text: 'Por favor, preencha as datas antes de exportar.', background: isDark ? '#213448' : '#ffffff', color: isDark ? '#EAE0CF' : '#213448', confirmButtonColor: '#547792', customClass: { popup: 'rounded-4' } });
        return;
        }

        const d1 = new Date(dataInicio + 'T00:00:00');
        const d2 = new Date(dataFim + 'T00:00:00');

        if (d1 > d2) {
        Swal.fire({ icon: 'error', title: 'Intervalo inválido!', text: 'A Data Inicial não pode ser maior que a Data Final.', background: isDark ? '#213448' : '#ffffff', color: isDark ? '#EAE0CF' : '#213448', confirmButtonColor: '#547792', customClass: { popup: 'rounded-4' } });
        return;
        }

        const limiteExport = new Date(d1.getTime());
        limiteExport.setFullYear(limiteExport.getFullYear() + 1);

        if (d2 > limiteExport) {
        Swal.fire({ icon: 'warning', title: 'Limite atingido!', text: 'O limite máximo para exportação é de exato 1 ano.', background: isDark ? '#213448' : '#ffffff', color: isDark ? '#EAE0CF' : '#213448', confirmButtonColor: '#547792', customClass: { popup: 'rounded-4' } });
        return;
        }

        const url = `@Url.Action("ExportarCsv")?dataInicio=${dataInicio}&dataFim=${dataFim}`;
        window.location.href = url;
        }
    </script>
}
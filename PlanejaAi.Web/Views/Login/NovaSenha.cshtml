@{
    Layout = null;
    string token = ViewBag.Token;
}

<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Nova Senha - Planeja Aí</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />

    <style>
        :root {
            --cor-escura: #213448;
            --cor-media: #547792;
            --cor-clara: #94B4C1;
            --cor-bege: #EAE0CF;
            --bg-fundo: var(--cor-bege);
            --bg-cartao: #ffffff;
            --texto-principal: var(--cor-escura);
            --btn-bg: var(--cor-media);
            --btn-texto: #ffffff;
        }

        [data-theme="dark"] {
            --bg-fundo: var(--cor-escura);
            --bg-cartao: var(--cor-media);
            --texto-principal: var(--cor-bege);
            --btn-bg: var(--cor-clara);
            --btn-texto: var(--cor-escura);
        }

        body {
            background-color: var(--bg-fundo);
            color: var(--texto-principal);
            transition: background-color 0.3s ease, color 0.3s ease;
            height: 100vh;
            display: flex;
            flex-direction: column;
            margin: 0;
        }

        .top-bar {
            width: 100%;
            padding: 20px 40px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .logo-container {
            display: flex;
            align-items: center;
        }

        .custom-logo-size {
            height: 60px;
            width: auto;
        }

        .logo-dark {
            display: none;
        }

        :root:not([data-theme="dark"]) .icon-sun, :root:not([data-theme="dark"]) .logo-light {
            display: block;
        }

        [data-theme="dark"] .icon-moon, [data-theme="dark"] .logo-dark {
            display: block;
        }

        .logo-text {
            font-size: 1.8rem;
            font-weight: 700;
            margin-left: 10px;
        }

        .theme-toggle-btn {
            background: none;
            border: none;
            cursor: pointer;
            display: flex;
            align-items: center;
        }

        .icon-sun, .icon-moon {
            display: none;
            width: 28px;
            height: 28px;
        }

        .icon-sun {
            fill: var(--cor-escura);
        }

        .icon-moon {
            fill: var(--cor-bege);
        }

        .login-container {
            flex-grow: 1;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 20px;
        }

        .login-card {
            background-color: var(--bg-cartao);
            border-radius: 12px;
            box-shadow: 0 8px 24px rgba(0,0,0,0.15);
            width: 100%;
            max-width: 420px;
            padding: 40px;
        }

        .btn-custom {
            background-color: var(--btn-bg);
            color: var(--btn-texto);
            font-weight: bold;
            border: none;
            padding: 12px;
        }

            .btn-custom:hover {
                filter: brightness(0.9);
                color: var(--btn-texto);
            }

        [data-theme="dark"] .form-control {
            background-color: var(--cor-escura);
            color: var(--cor-bege);
            border: 1px solid var(--cor-clara);
        }
    </style>
</head>
<body>

    <div class="top-bar">
        <div class="logo-container d-flex align-items-center">
            <img src="/images/logo-claro.svg" alt="Logo" class="logo-light custom-logo-size" />
            <img src="/images/logo-escuro.svg" alt="Logo" class="logo-dark custom-logo-size" />
            <span class="logo-text d-none d-md-block">Planeja Aí</span>
        </div>

        <button id="themeToggle" class="theme-toggle-btn">
            <svg class="icon-sun" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16"><path d="M8 11a3 3 0 1 1 0-6 3 3 0 0 1 0 6zm0 1a4 4 0 1 0 0-8 4 4 0 0 0 0 8zM8 0a.5.5 0 0 1 .5.5v2a.5.5 0 0 1-1 0v-2A.5.5 0 0 1 8 0zm0 13a.5.5 0 0 1 .5.5v2a.5.5 0 0 1-1 0v-2A.5.5 0 0 1 8 13zm8-5a.5.5 0 0 1-.5.5h-2a.5.5 0 0 1 0-1h2a.5.5 0 0 1 .5.5zM3 8a.5.5 0 0 1-.5.5h-2a.5.5 0 0 1 0-1h2A.5.5 0 0 1 3 8zm10.657-5.657a.5.5 0 0 1 0 .707l-1.414 1.415a.5.5 0 1 1-.707-.708l1.414-1.414a.5.5 0 0 1 .707 0zm-9.193 9.193a.5.5 0 0 1 0 .707L3.05 13.657a.5.5 0 0 1-.707-.707l1.414-1.414a.5.5 0 0 1 .707 0zm9.193 2.121a.5.5 0 0 1-.707 0l-1.414-1.414a.5.5 0 0 1 .707-.707l1.414 1.414a.5.5 0 0 1 0 .707zM4.464 4.465a.5.5 0 0 1-.707 0L2.343 3.05a.5.5 0 1 1 .707-.707l1.414 1.414a.5.5 0 0 1 0 .708z" /></svg>
            <svg class="icon-moon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16"><path d="M6 .278a.768.768 0 0 1 .08.858 7.208 7.208 0 0 0-.878 3.46c0 4.021 3.278 7.277 7.318 7.277.527 0 1.04-.055 1.533-.16a.787.787 0 0 1 .81.316.733.733 0 0 1-.031.893A8.349 8.349 0 0 1 8.344 16C3.734 16 0 12.286 0 7.71 0 4.266 2.114 1.312 5.124.06A.752.752 0 0 1 6 .278z" /></svg>
        </button>
    </div>

    <div class="login-container">
        <div class="login-card shadow">

            @if (TempData["Erro"] != null || string.IsNullOrEmpty(token))
            {
                <div class="text-center">
                    <i class="fa-solid fa-circle-exclamation text-danger mb-3" style="font-size: 3rem;"></i>
                    <h2 style="font-weight: 700;">Link Inválido</h2>
                    <p>@(TempData["Erro"] ?? "O token de recuperação é inválido ou expirou.")</p>
                    <a asp-action="Index" class="btn btn-custom w-100 mt-3">Voltar para o Login</a>
                </div>
            }
            else
            {
                <div class="text-center mb-4">
                    <h2 style="font-weight: 700;">Nova Senha</h2>
                    <p>Crie uma senha forte para sua segurança.</p>
                </div>

                @* MENSAGEM DE ERRO VINDA DO CONTROLLER (C#) *@
                @if (ViewBag.Erro != null)
                {
                    <div class="alert alert-danger text-center py-2 mb-3" style="font-size: 0.85rem;">
                        <i class="fa-solid fa-triangle-exclamation me-2"></i> @ViewBag.Erro
                    </div>
                }
            
                <form asp-action="NovaSenha" method="post" novalidate class="needs-validation">
                    <input type="hidden" name="token" value="@token" />

                    <div class="mb-4">
                        <label class="form-label">Nova Senha</label>
                        <input type="password"
                               name="novaSenha"
                               id="novaSenha"
                               class="form-control"
                               required
                               minlength="8"
                               @* REGEX ATUALIZADO: (?=.*\d) garante pelo menos um número *@
                               pattern="^(?=.*[A-Z])(?=.*\d)(?=.*[!@@#$%^&*()_+\-=\[\]{};':\\|,.<>\/?]).{8,}$"
                               placeholder="Digite a nova senha" />

                        <div class="invalid-feedback">
                            A senha não atende aos requisitos mínimos de segurança.
                        </div>

                        @* Legenda formal abaixo do campo *@
                        <div class="mt-2 text-muted" style="font-size: 0.8rem; line-height: 1.4;">
                            <i class="fa-solid fa-shield-halved me-1"></i>
                            Diretriz de Segurança: A senha deve conter no mínimo 8 caracteres, incluindo obrigatoriamente letras maiúsculas, números e caracteres especiais.
                        </div>
                    </div>

                    <button type="submit" class="btn btn-custom w-100 mb-2">Redefinir Senha</button>
                </form>
            }
        </div>
    </div>

    <script>
        // Tema
        const currentTheme = localStorage.getItem('theme');
        if (currentTheme) { document.documentElement.setAttribute('data-theme', currentTheme); }

        document.getElementById('themeToggle').addEventListener('click', () => {
            let theme = document.documentElement.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
            if (theme === 'dark') { document.documentElement.setAttribute('data-theme', 'dark'); }
            else { document.documentElement.removeAttribute('data-theme'); }
            localStorage.setItem('theme', theme);
        });

        // Validação do formulário
        (function () {
            'use strict'
            var forms = document.querySelectorAll('.needs-validation')
            Array.prototype.slice.call(forms).forEach(function (form) {
                form.addEventListener('submit', function (event) {
                    if (!form.checkValidity()) {
                        event.preventDefault()
                        event.stopPropagation()
                    }
                    form.classList.add('was-validated')
                }, false)
            })
        })()
    </script>
</body>
</html>
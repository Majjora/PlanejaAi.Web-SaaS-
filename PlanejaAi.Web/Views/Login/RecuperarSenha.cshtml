@{
    ViewData["Title"] = "Recuperar Senha - Planeja Aí";
    Layout = null;
}

<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <style>
        
        :root {
            --cor-escura: #213448;
            --cor-media: #547792;
            --cor-clara: #94B4C1;
            --cor-bege: #EAE0CF;
            --bg-fundo: var(--cor-bege);
            --bg-cartao: #ffffff;
            --texto-principal: var(--cor-escura);
            --btn-bg: var(--cor-media);
            --btn-texto: #ffffff;
            --link-cor: var(--cor-media);
        }

        [data-theme="dark"] {
            --bg-fundo: var(--cor-escura);
            --bg-cartao: var(--cor-media);
            --texto-principal: var(--cor-bege);
            --btn-bg: var(--cor-clara);
            --btn-texto: var(--cor-escura);
            --link-cor: var(--cor-bege);
        }

        body {
            background-color: var(--bg-fundo);
            color: var(--texto-principal);
            transition: 0.3s;
            height: 100vh;
            display: flex;
            flex-direction: column;
            margin: 0;
        }

        .top-bar {
            width: 100%;
            padding: 20px 40px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .custom-logo-size {
            height: 60px;
            width: auto;
        }

        .logo-text {
            font-size: 1.8rem;
            font-weight: 700;
            margin-left: 10px;
        }

        .theme-toggle-btn {
            background: none;
            border: none;
            cursor: pointer;
            padding: 8px;
            display: flex;
            align-items: center;
        }

        .icon-sun, .icon-moon {
            display: none;
            width: 28px;
            height: 28px;
        }

        :root:not([data-theme="dark"]) .icon-sun, :root:not([data-theme="dark"]) .logo-light {
            display: block;
        }

        [data-theme="dark"] .icon-moon, [data-theme="dark"] .logo-dark {
            display: block;
        }

        :root:not([data-theme="dark"]) .logo-dark, [data-theme="dark"] .logo-light {
            display: none;
        }

        .icon-sun {
            fill: var(--cor-escura);
        }

        .icon-moon {
            fill: var(--cor-bege);
        }

        .login-container {
            flex-grow: 1;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 20px;
        }

        .login-card {
            background-color: var(--bg-cartao);
            border-radius: 12px;
            box-shadow: 0 8px 24px rgba(0,0,0,0.15);
            width: 100%;
            max-width: 420px;
            padding: 40px;
        }

        .btn-custom {
            background-color: var(--btn-bg);
            color: var(--btn-texto);
            font-weight: bold;
            border: none;
            padding: 12px;
        }

        .custom-link {
            color: var(--link-cor);
            text-decoration: none;
            font-weight: 500;
        }

        [data-theme="dark"] .form-control {
            background-color: var(--cor-escura);
            color: var(--cor-bege);
            border: 1px solid var(--cor-clara);
        }
    </style>
</head>
<body>
    <div class="top-bar">
        <div class="logo-container d-flex align-items-center">
            <img src="/images/logo-claro.svg" alt="Logo" class="logo-light custom-logo-size" />
            <img src="/images/logo-escuro.svg" alt="Logo" class="logo-dark custom-logo-size" />
            <span class="logo-text d-none d-md-block">Planeja Aí</span>
        </div>
        <button id="themeToggle" class="theme-toggle-btn">
            <svg class="icon-sun" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16"><path d="M8 11a3 3 0 1 1 0-6 3 3 0 0 1 0 6zm0 1a4 4 0 1 0 0-8 4 4 0 0 0 0 8zM8 0a.5.5 0 0 1 .5.5v2a.5.5 0 0 1-1 0v-2A.5.5 0 0 1 8 0zm0 13a.5.5 0 0 1 .5.5v2a.5.5 0 0 1-1 0v-2A.5.5 0 0 1 8 13zm8-5a.5.5 0 0 1-.5.5h-2a.5.5 0 0 1 0-1h2a.5.5 0 0 1 .5.5zM3 8a.5.5 0 0 1-.5.5h-2a.5.5 0 0 1 0-1h2A.5.5 0 0 1 3 8zm10.657-5.657a.5.5 0 0 1 0 .707l-1.414 1.415a.5.5 0 1 1-.707-.708l1.414-1.414a.5.5 0 0 1 .707 0zm-9.193 9.193a.5.5 0 0 1 0 .707L3.05 13.657a.5.5 0 0 1-.707-.707l1.414-1.414a.5.5 0 0 1 .707 0zm9.193 2.121a.5.5 0 0 1-.707 0l-1.414-1.414a.5.5 0 0 1 .707-.707l1.414 1.414a.5.5 0 0 1 0 .707zM4.464 4.465a.5.5 0 0 1-.707 0L2.343 3.05a.5.5 0 1 1 .707-.707l1.414 1.414a.5.5 0 0 1 0 .708z" /></svg>
            <svg class="icon-moon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16"><path d="M6 .278a.768.768 0 0 1 .08.858 7.208 7.208 0 0 0-.878 3.46c0 4.021 3.278 7.277 7.318 7.277.527 0 1.04-.055 1.533-.16a.787.787 0 0 1 .81.316.733.733 0 0 1-.031.893A8.349 8.349 0 0 1 8.344 16C3.734 16 0 12.286 0 7.71 0 4.266 2.114 1.312 5.124.06A.752.752 0 0 1 6 .278z" /></svg>
        </button>
    </div>

    <div class="login-container">
        <div class="login-card">
            <div class="text-center mb-4">
                <h2>Recuperar Senha</h2>
                <p>Informe seu e-mail para as instruções.</p>
            </div>

            @if (ViewBag.Mensagem != null)
            {
                <div class="alert alert-success text-center">@ViewBag.Mensagem</div>
            }
            @if (ViewBag.Erro != null)
            {
                <div class="alert alert-danger text-center">@ViewBag.Erro</div>
            }

            <form asp-action="RecuperarSenha" method="post" novalidate class="needs-validation">
                <div class="mb-4">
                    <label for="email" class="form-label mb-1">E-mail corporativo</label>
                    <input type="email" class="form-control" id="email" name="email" placeholder="Digite o e-mail cadastrado" required />
                    <div class="invalid-feedback">Informe o e-mail para recuperação.</div>
                </div>

                <button type="submit" class="btn btn-custom w-100 mb-4">Enviar Link</button>

                <div class="text-center">
                    <a asp-controller="Login" asp-action="Index" class="custom-link">Voltar para o Login</a>
                </div>
            </form>
        </div>
    </div>

    <script>
        
        if (localStorage.getItem('theme')) { document.documentElement.setAttribute('data-theme', localStorage.getItem('theme')); }

        document.getElementById('themeToggle').addEventListener('click', () => {
            let theme = document.documentElement.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
            theme === 'dark' ? document.documentElement.setAttribute('data-theme', 'dark') : document.documentElement.removeAttribute('data-theme');
            localStorage.setItem('theme', theme);
        });

        const form = document.querySelector('.needs-validation');
        form.addEventListener('submit', function (event) {
            if (!form.checkValidity()) { event.preventDefault(); event.stopPropagation(); }
            form.classList.add('was-validated');
        }, false);
    </script>
</body>
</html>
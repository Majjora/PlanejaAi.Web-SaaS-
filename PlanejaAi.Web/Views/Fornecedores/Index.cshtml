@model IList<PlanejaAi.Models.Fornecedor>

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<style>
    :root {
        --cor-escura: #213448;
        --cor-media: #547792;
        --cor-clara: #94B4C1;
        --cor-bege: #EAE0CF;
    }

    body {
        background-color: var(--cor-bege) !important;
        color: var(--cor-escura);
        transition: all 0.3s ease;
    }

    [data-theme="dark"] body {
        background-color: var(--cor-escura) !important;
        color: var(--cor-bege);
    }

    .card-planeja {
        background-color: #ffffff;
        border-radius: 12px;
        border: none;
        box-shadow: 0 8px 24px rgba(0,0,0,0.1);
        padding: 20px;
    }

    [data-theme="dark"] .card-planeja {
        background-color: var(--cor-media) !important;
    }

    .search-container .form-control {
        background-color: rgba(255, 255, 255, 0.5);
        border: 1px solid var(--cor-media);
        color: var(--cor-escura) !important;
    }

    [data-theme="dark"] .search-container .form-control {
        background-color: var(--cor-escura) !important;
        color: #ffffff !important;
    }

    .thead-planeja th {
        color: var(--cor-media) !important;
        font-weight: 700;
        text-transform: uppercase;
        font-size: 0.85rem;
    }

    .table tbody td {
        color: #000000 !important;
    }

    [data-theme="dark"] .thead-planeja th {
        color: var(--cor-bege) !important;
    }

    [data-theme="dark"] .table tbody td {
        color: #ffffff !important;
    }

        [data-theme="dark"] .table tbody td .text-muted {
            color: var(--cor-clara) !important;
        }

    .thead-planeja {
        background-color: rgba(33, 52, 72, 0.05);
    }

    .btn-planeja-primary {
        background-color: var(--cor-media);
        color: white;
        border: none;
        font-weight: bold;
        transition: all 0.3s ease;
    }

        .btn-planeja-primary:hover {
            background-color: var(--cor-escura);
            color: white;
            transform: translateY(-2px);
            box-shadow: 0 6px 15px rgba(0, 0, 0, 0.2) !important;
        }

    [data-theme="dark"] .btn-planeja-primary {
        background-color: var(--cor-clara);
        color: var(--cor-escura);
    }

        [data-theme="dark"] .btn-planeja-primary:hover {
            background-color: #ffffff;
            color: var(--cor-escura);
            transform: translateY(-2px);
            box-shadow: 0 6px 15px rgba(0, 0, 0, 0.5) !important;
        }

    .texto-identificador-empresa {
        color: var(--cor-media);
        font-weight: 600;
        transition: color 0.3s ease;
    }

    [data-theme="dark"] .texto-identificador-empresa {
        color: var(--cor-clara) !important;
    }
</style>

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="m-0 fw-bold" style="color: var(--cor-media);">Gestão de Fornecedores</h2>
            <p class="text-muted m-0">Administre os fornecedores da sua empresa</p>
        </div>

        <div class="d-flex gap-2">
            <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary btn-sm px-3 shadow-sm">
                <i class="fa-solid fa-house me-2"></i>Início
            </a>

            <a asp-controller="CategoriasServico" asp-action="Index" class="btn btn-outline-secondary btn-sm px-3 shadow-sm" title="Gerenciar Categorias de Serviço">
                <i class="fa-solid fa-tags me-2"></i>Categorias
            </a>

            <a asp-controller="ProdutosFornecedor" asp-action="Index" class="btn btn-outline-secondary btn-sm px-3 shadow-sm">
                <i class="fa-solid fa-box me-2"></i>Produtos
            </a>

            <a asp-action="Criar" class="btn btn-planeja-primary btn-sm px-3 shadow-sm">
                <i class="fa-solid fa-plus me-2"></i>Novo Fornecedor
            </a>
        </div>
    </div>

    <div class="mb-4 search-container">
        <form asp-action="Index" method="get" class="d-flex gap-2" onsubmit="return false;">
            <div class="input-group shadow-sm" style="max-width: 450px;">
                <span class="input-group-text border-0" style="background-color: var(--cor-media); color: white;">
                    <i class="fa-solid fa-magnifying-glass"></i>
                </span>
                <input type="text" id="inputBusca" name="busca" class="form-control" placeholder="Buscar por nome ou e-mail..." value="@ViewData["FiltroAtual"]">
            </div>
            <button type="button" id="btnPesquisar" class="btn btn-planeja-primary px-4 shadow-sm">Pesquisar</button>
        </form>
    </div>

    <div class="card-planeja shadow-sm">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="thead-planeja">
                    <tr>
                        <th class="ps-4 border-0">Fornecedor</th>
                        <th class="border-0">Contato</th>
                        <th class="border-0">Status</th>
                        <th class="text-end pe-4 border-0">Ações</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.Count == 0)
                    {
                        <tr>
                            <td colspan="4" class="text-center py-5 text-muted fst-italic">Nenhum fornecedor cadastrado.</td>
                        </tr>
                    }
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="ps-4">
                                <div class="fw-bold">@item.Nome</div>
                                <div class="text-muted small">Doc: @(item.CnpjCpf ?? "Não informado")</div>
                                <small class="text-muted d-block">Cadastrado em: @item.DataCadastro.ToString("dd/MM/yyyy")</small>

                                @if (User.IsInRole("owner"))
                                {
                                    <div class="small mt-1 texto-identificador-empresa">
                                        <i class="fa-solid fa-building me-1"></i> Empresa: @(item.Empresa?.Nome ?? "Não informada")
                                    </div>
                                }
                            </td>
                            <td>
                                <div><i class="fa-solid fa-envelope me-1"></i> @(item.Email ?? "Sem e-mail")</div>
                                <small class="text-muted"><i class="fa-solid fa-phone me-1"></i> @(item.Telefone ?? "Sem telefone")</small>
                            </td>
                            <td>
                                @if (item.Status)
                                {
                                    <span class="badge bg-success">Ativo</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">Inativo</span>
                                }
                            </td>
                            <td class="text-end pe-4">
                                <div class="d-flex justify-content-end gap-2">

                                    <a asp-controller="ProdutosFornecedor" asp-action="Index" asp-route-fornecedorId="@item.Id" class="btn btn-sm text-primary" title="Visualizar Produtos">
                                        <i class="fa-solid fa-eye"></i>
                                    </a>

                                    <a asp-action="Editar" asp-route-id="@item.Id" class="btn btn-sm text-info" title="Editar">
                                        <i class="fa-solid fa-pen"></i>
                                    </a>

                                    @if (User.IsInRole("admin") || User.IsInRole("owner"))
                                    {
                                        <form asp-action="Deletar" asp-route-id="@item.Id" method="post" class="d-inline form-excluir">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm text-danger btn-excluir" data-nome="@item.Nome" title="Excluir">
                                                <i class="fa-solid fa-trash"></i>
                                            </button>
                                        </form>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<script>
    document.addEventListener("DOMContentLoaded", function() {
        const isDark = document.documentElement.getAttribute('data-theme') === 'dark';
        const erroMsg = '@Html.Raw(TempData["Erro"])';
        const sucessoMsg = '@Html.Raw(TempData["Sucesso"])';

        if (erroMsg) {
            Swal.fire({ icon: 'error', title: 'Ops!', text: erroMsg, background: isDark ? '#213448' : '#ffffff', color: isDark ? '#EAE0CF' : '#213448', confirmButtonColor: '#547792' });
        }
        if (sucessoMsg) {
            Swal.fire({ icon: 'success', title: 'Sucesso!', text: sucessoMsg, background: isDark ? '#213448' : '#ffffff', color: isDark ? '#EAE0CF' : '#213448', confirmButtonColor: '#547792' });
        }
    });

    document.querySelectorAll('.form-excluir').forEach(form => {
        form.addEventListener('submit', function (e) {
            e.preventDefault();
            const btn = this.querySelector('.btn-excluir');
            const nome = btn.getAttribute('data-nome');
            const isDark = document.documentElement.getAttribute('data-theme') === 'dark';

            Swal.fire({
                title: 'Excluir?',
                text: `Deseja remover o fornecedor ${nome}?`,
                icon: 'warning',
                showCancelButton: true,
                background: isDark ? '#213448' : '#ffffff',
                color: isDark ? '#EAE0CF' : '#213448',
                confirmButtonColor: '#dc3545',
                cancelButtonColor: '#547792',
                confirmButtonText: 'Sim, excluir',
                cancelButtonText: 'Cancelar'
            }).then((result) => {
                if (result.isConfirmed) { HTMLFormElement.prototype.submit.call(this); }
            });
        });
    });

    function aplicarFiltro() {
        let textoBusca = document.getElementById('inputBusca').value.toLowerCase();
        let linhasTabela = document.querySelectorAll('.table tbody tr');

        linhasTabela.forEach(function (linha) {
            let primeiraCelula = linha.querySelector('td');
            if (primeiraCelula && primeiraCelula.getAttribute('colspan') === '4') return;
            let textoDaLinha = linha.textContent.toLowerCase();
            linha.style.display = textoDaLinha.includes(textoBusca) ? '' : 'none';
        });
    }

    document.getElementById('inputBusca').addEventListener('keyup', aplicarFiltro);
    document.getElementById('btnPesquisar').addEventListener('click', aplicarFiltro);
</script>
@model PlanejaAi.Models.Cliente

@{
    ViewData["Title"] = "Detalhes do Cliente";
}

<style>
    :root {
        --cor-escura: #213448;
        --cor-media: #547792;
        --cor-clara: #94B4C1;
        --cor-bege: #EAE0CF;
    }

    body {
        background-color: var(--cor-bege) !important;
        color: var(--cor-escura);
        transition: all 0.3s ease;
    }

    [data-theme="dark"] body {
        background-color: var(--cor-escura) !important;
        color: var(--cor-bege);
    }

    .card-planeja {
        background-color: #ffffff;
        border-radius: 12px;
        border: none;
        box-shadow: 0 8px 24px rgba(0,0,0,0.1);
        padding: 30px;
        transition: all 0.3s ease;
    }

    [data-theme="dark"] .card-planeja {
        background-color: var(--cor-media) !important;
        box-shadow: 0 8px 24px rgba(0,0,0,0.3);
    }

    .form-label {
        color: var(--cor-media);
        font-weight: 700;
        margin-bottom: 0.4rem;
    }

    [data-theme="dark"] .form-label {
        color: var(--cor-bege);
    }

    .info-box {
        background-color: rgba(255, 255, 255, 0.8);
        border: 1px solid var(--cor-clara);
        color: var(--cor-escura);
        padding: 0.375rem 0.75rem;
        border-radius: 0.375rem;
        min-height: 38px;
        display: flex;
        align-items: center;
    }

    [data-theme="dark"] .info-box {
        background-color: var(--cor-escura);
        border-color: var(--cor-clara);
        color: #ffffff;
    }

    .main-title {
        color: var(--cor-media);
        transition: color 0.3s ease;
    }

    [data-theme="dark"] .main-title {
        color: var(--cor-bege) !important;
    }

    .section-title {
        color: var(--cor-media);
        font-size: 0.85rem;
        letter-spacing: 1px;
        margin-top: 2rem;
        transition: color 0.3s ease;
    }

    [data-theme="dark"] .section-title {
        color: var(--cor-bege) !important;
    }

    [data-theme="dark"] hr {
        border-color: var(--cor-bege);
        opacity: 0.2;
    }

    .btn-planeja-primary {
        background-color: var(--cor-media);
        color: white;
        border: none;
        font-weight: bold;
        transition: all 0.3s ease;
    }

    [data-theme="dark"] .btn-planeja-primary {
        background-color: var(--cor-clara);
        color: var(--cor-escura);
    }

    .btn-planeja-primary:hover {
        background-color: var(--cor-escura);
        color: white;
    }

    [data-theme="dark"] .btn-planeja-primary:hover {
        background-color: #ffffff;
        color: var(--cor-escura);
    }

    .btn-planeja-outline {
        border: 1px solid var(--cor-media);
        color: var(--cor-media);
        font-weight: 500;
        background-color: transparent;
        transition: all 0.3s ease;
    }

    [data-theme="dark"] .btn-planeja-outline {
        border: 1px solid var(--cor-bege);
        color: var(--cor-bege);
    }

    .btn-planeja-outline:hover {
        background-color: var(--cor-media);
        color: white;
    }

    [data-theme="dark"] .btn-planeja-outline:hover {
        background-color: var(--cor-bege);
        color: var(--cor-escura);
    }
</style>

<div class="container mt-5 mb-5">
    <div class="card-planeja shadow-sm">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="m-0 fw-bold main-title">
                <i class="fa-solid fa-user me-2"></i> @ViewData["Title"]
            </h2>
        </div>

        <div class="row g-3">

            <div class="col-md-6">
                <label class="form-label">Nome do Cliente</label>
                <div class="info-box">@Model.Nome</div>
            </div>
            <div class="col-md-3">
                <label class="form-label">CPF/CNPJ</label>
                <div class="info-box d-flex justify-content-between align-items-center">
                    @if (string.IsNullOrEmpty(Model.Documento))
                    {
                        <span>Não informado</span>
                    }
                    else
                    {
                        @if (User.IsInRole("admin") || User.IsInRole("owner") || User.IsInRole("Admin") || User.IsInRole("Owner"))
                        {
                            <span class="doc-oculto fw-bold" data-doc="@Model.Documento" style="letter-spacing: 1px;">***.***.***-**</span>
                            <button type="button" class="btn btn-sm text-secondary p-0 btn-toggle-doc" title="Revelar Documento">
                                <i class="fa-solid fa-eye"></i>
                            </button>
                        }
                        else
                        {
                            <span class="fw-bold" style="letter-spacing: 1px;">***.***.***-**</span>
                        }
                    }
                </div>
            </div>
            <div class="col-md-3">
                <label class="form-label">Status</label>
                <div class="info-box border-0 bg-transparent p-0">
                    @if (Model.Status)
                    {
                        <span class="badge bg-success w-100 py-2 fs-6">Ativo</span>
                    }
                    else
                    {
                        <span class="badge bg-danger w-100 py-2 fs-6">Inativo</span>
                    }
                </div>
            </div>

            <div class="col-md-6">
                <label class="form-label">E-mail</label>
                <div class="info-box">@(string.IsNullOrEmpty(Model.Email) ? "Não informado" : Model.Email)</div>
            </div>
            <div class="col-md-6">
                <label class="form-label">Telefone</label>
                <div class="info-box">@(string.IsNullOrEmpty(Model.Telefone) ? "Não informado" : Model.Telefone)</div>
            </div>

            @if (User.IsInRole("owner"))
            {
                <div class="col-12 mt-2">
                    <label class="form-label text-warning mb-1"><i class="fa-solid fa-building me-1"></i> Empresa Vinculada</label>
                    <div class="info-box fw-bold" style="border-color: #ffc107;">@(Model.Empresa?.Nome ?? "Não informada")</div>
                </div>
            }

            <div class="col-12">
                <h5 class="section-title text-uppercase fw-bold">Endereço</h5>
                <hr style="opacity: 0.1;" class="mt-1" />
            </div>

            <div class="col-md-3">
                <label class="form-label">CEP</label>
                <div class="info-box">@(string.IsNullOrEmpty(Model.Cep) ? "-" : Model.Cep)</div>
            </div>
            <div class="col-md-7">
                <label class="form-label">Logradouro</label>
                <div class="info-box">@(string.IsNullOrEmpty(Model.Logradouro) ? "-" : Model.Logradouro)</div>
            </div>
            <div class="col-md-2">
                <label class="form-label">Nº</label>
                <div class="info-box">@(string.IsNullOrEmpty(Model.Numero) ? "-" : Model.Numero)</div>
            </div>

            <div class="col-md-5">
                <label class="form-label">Bairro</label>
                <div class="info-box">@(string.IsNullOrEmpty(Model.Bairro) ? "-" : Model.Bairro)</div>
            </div>
            <div class="col-md-5">
                <label class="form-label">Cidade</label>
                <div class="info-box">@(string.IsNullOrEmpty(Model.Cidade) ? "-" : Model.Cidade)</div>
            </div>
            <div class="col-md-2">
                <label class="form-label">UF</label>
                <div class="info-box">@(string.IsNullOrEmpty(Model.Uf) ? "-" : Model.Uf)</div>
            </div>
        </div>

        <div class="mt-5 d-flex gap-2">
            <a asp-action="Index" class="btn btn-planeja-outline px-4 py-2">
                <i class="fa-solid fa-arrow-left me-2"></i> Voltar
            </a>
            <a asp-action="Manter" asp-route-id="@Model.Id" class="btn btn-planeja-primary px-5 py-2 shadow-sm">
                <i class="fa-solid fa-pen me-2"></i> Editar Cliente
            </a>
        </div>
    </div>
</div>
<script>
    document.querySelectorAll('.btn-toggle-doc').forEach(btn => {
    btn.addEventListener('click', function(e) {
    e.preventDefault();
    const icone = this.querySelector('i');
    const spanDoc = this.previousElementSibling;
    const docReal = spanDoc.getAttribute('data-doc');

    if (icone.classList.contains('fa-eye')) {
    spanDoc.textContent = docReal;
    icone.classList.remove('fa-eye');
    icone.classList.add('fa-eye-slash');
    this.title = "Ocultar Documento";
    } else {
    spanDoc.textContent = '***.***.***-**';
    icone.classList.remove('fa-eye-slash');
    icone.classList.add('fa-eye');
    this.title = "Revelar Documento";
    }
    });
    });
</script>
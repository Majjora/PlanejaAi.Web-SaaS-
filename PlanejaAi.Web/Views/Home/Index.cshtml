@{
    ViewData["Title"] = "Home";
}

<style>
    /* -----------------------------------------------------------
           1. VARIAVEIS DE CORES - Refinamento da Paleta "Planeja Aí"
           ----------------------------------------------------------- */
    :root {
        /* Originais da sua paleta (para referência) */
        --p-clara: #94B4C1;
        --p-bege: #EAE0CF;
        --p-escura: #213448;
        --p-media: #547792;
        /* --- CONFIGURAÇÃO TEMA CLARO (SOL) - REFINADO --- */
        /* Mudamos o fundo bege para um branco limpo e usamos o bege em bordas */
        --bg-body: #ffffff;
        --bg-card: #fdfdfd;
        --text-main: var(--p-escura);
        --text-muted: var(--p-media);
        --accent: var(--p-media);
        --border-card: var(--p-bege); /* Bege como detalhe sutil */
        /* Banner Claro: Gradiente suave usando o azul claro da paleta */
        --banner-grad: linear-gradient(135deg, var(--p-media), var(--p-clara));
        --shadow-main: 0 4px 15px rgba(33, 52, 72, 0.05);
    }

    [data-theme="dark"] {
        /* --- CONFIGURAÇÃO TEMA ESCURO (LUA) --- */
        --bg-body: var(--p-escura);
        --bg-card: rgba(33, 52, 72, 0.7); /* Azul escuro com transparência */
        --text-main: var(--p-bege);
        --text-muted: var(--p-clara);
        --accent: var(--p-clara);
        --border-card: rgba(148, 180, 193, 0.1); /* Azul claro bem sutil */
        /* Banner Escuro: Gradiente profundo */
        --banner-grad: linear-gradient(135deg, #111e29, #000000);
        --shadow-main: 0 10px 30px rgba(0,0,0,0.5);
    }

    /* -----------------------------------------------------------
           2. ESTILOS GERAIS E RESPONSIVIDADE
           ----------------------------------------------------------- */
    body {
        background-color: var(--bg-body);
        color: var(--text-main);
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
    }

    .home-container {
        padding: 30px 15px;
        max-width: 1200px;
        margin: 0 auto;
    }

    /* --- Banner --- */
    .welcome-banner {
        background: var(--banner-grad);
        padding: 40px;
        border-radius: 20px;
        margin-bottom: 40px;
        box-shadow: var(--shadow-main);
    }

    /* --- Grid de Cards Responsiva --- */
    /* row-cols-1 (mobile), row-cols-md-2 (tablet), row-cols-lg-3 (desktop) */
    .card-modulo {
        background-color: var(--bg-card);
        border: 2px solid var(--border-card);
        border-radius: 20px;
        padding: 2.5rem 1.5rem;
        transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        text-align: center;
        height: 100%; /* Garante altura igual */
        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
    }

        .card-modulo:hover {
            transform: translateY(-8px);
            box-shadow: var(--shadow-main);
            border-color: var(--accent);
        }

    .icon-box {
        font-size: 2.5rem;
        color: var(--accent);
        margin-bottom: 1rem;
        transition: 0.3s;
    }

    .card-modulo:hover .icon-box {
        transform: scale(1.1);
    }

    .card-title {
        font-weight: 700;
        font-size: 1.3rem;
        margin-bottom: 0.5rem;
    }

    .card-text {
        color: var(--text-muted);
        font-size: 0.95rem;
        margin-bottom: 0;
    }

    a {
        text-decoration: none !important;
        color: inherit !important;
    }

    /* --- Chatbot FAB --- */
    .chatbot-fab {
        position: fixed;
        bottom: 30px;
        right: 30px;
        width: 65px;
        height: 65px;
        background-color: var(--cor-media, #547792); /* Fallback case layout não carregue */
        color: white;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 26px;
        cursor: pointer;
        box-shadow: 0 8px 25px rgba(84, 119, 146, 0.3);
        z-index: 1000;
        transition: all 0.3s ease;
    }

        .chatbot-fab:hover {
            transform: scale(1.1) rotate(10deg);
        }

    /* --- Footer Políticos --- */
    .footer-politica {
        margin-top: 60px;
        padding: 20px;
        text-align: center;
        border-top: 1px solid var(--border-card);
        color: var(--text-muted);
        font-size: 0.85rem;
    }
</style>

<div class="home-container">
    <div class="welcome-banner text-white">
        <h1 class="fw-bold">
            <i class="fa-regular fa-id-card me-2"></i>
            Bom dia, <span style="color: var(--p-bege);">@ViewBag.NomeUsuario</span>!
        </h1>
        <p class="fs-5 mb-0opacity-75">Vamos planejar algo incrível hoje?</p>
    </div>

    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
        <div class="col">
            <a href="@Url.Action("Criar", "Eventos")">
                <div class="card-modulo">
                    <div class="icon-box"><i class="fa-solid fa-wand-magic-sparkles"></i></div>
                    <h5 class="card-title">Criar Evento</h5>
                    <p class="card-text">Inicie um planejamento do zero.</p>
                </div>
            </a>
        </div>

        <div class="col">
            <a href="@Url.Action("Listar", "Eventos")">
                <div class="card-modulo">
                    <div class="icon-box"><i class="fa-solid fa-rectangle-list"></i></div>
                    <h5 class="card-title">Gerenciar</h5>
                    <p class="card-text">Acompanhe seus eventos ativos.</p>
                </div>
            </a>
        </div>

        <div class="col">
            <a href="@Url.Action("Index", "Fornecedores")">
                <div class="card-modulo">
                    <div class="icon-box"><i class="fa-solid fa-handshake"></i></div>
                    <h5 class="card-title">Fornecedores</h5>
                    <p class="card-text">Sua rede de parceiros parceiros.</p>
                </div>
            </a>
        </div>

        <div class="col">
            <a href="@Url.Action("Index", "Orcamentos")">
                <div class="card-modulo">
                    <div class="icon-box"><i class="fa-solid fa-coins"></i></div>
                    <h5 class="card-title">Financeiro</h5>
                    <p class="card-text">Controle de custos e propostas.</p>
                </div>
            </a>
        </div>

        <div class="col">
            <a href="@Url.Action("Sair", "Login")">
                <div class="card-modulo">
                    <div class="icon-box"><i class="fa-solid fa-right-from-bracket"></i></div>
                    <h5 class="card-title">Sair</h5>
                    <p class="card-text">Finalizar sessão com segurança.</p>
                </div>
            </a>
        </div>
    </div>

    <div class="footer-politica">
        <p>&copy; 2024 PlanejaAi - Soluções Integradas</p>
        <a href="#" class="me-3">Políticas de Privacidade</a> |
        <a href="#" class="ms-3">Termos de Uso</a>
    </div>
</div>

<div class="chatbot-fab" onclick="alert('IA Inicializando...')">
    <i class="fa-solid fa-robot"></i>
</div>
@model PlanejaAi.Models.Login

@{
    ViewData["Title"] = "Detalhes do Usuário";
}

<style>
    :root {
        --cor-escura: #213448;
        --cor-media: #547792;
        --cor-clara: #94B4C1;
        --cor-bege: #EAE0CF;
    }

    
    body {
        background-color: var(--cor-bege) !important;
        color: var(--cor-escura);
        transition: all 0.3s ease;
    }

    [data-theme="dark"] body {
        background-color: var(--cor-escura) !important;
        color: var(--cor-bege);
    }

    
    .card-planeja {
        background-color: #ffffff;
        border-radius: 12px;
        border: none;
        box-shadow: 0 8px 24px rgba(0,0,0,0.1);
        padding: 20px;
    }

    [data-theme="dark"] .card-planeja {
        background-color: var(--cor-media) !important;
        color: #ffffff;
    }

    
    .texto-primario {
        color: var(--cor-media);
    }

    [data-theme="dark"] .texto-primario {
        color: var(--cor-bege);
    }

    
    .info-box {
        background-color: rgba(33, 52, 72, 0.05);
        border: 1px solid transparent;
        color: #000000;
    }

    [data-theme="dark"] .info-box {
        background-color: var(--cor-escura);
        border: 1px solid var(--cor-escura);
        color: #ffffff;
    }

    
    .btn-planeja-primary {
        background-color: var(--cor-media);
        color: white;
        border: none;
        font-weight: bold;
    }

    [data-theme="dark"] .btn-planeja-primary {
        background-color: var(--cor-clara);
        color: var(--cor-escura);
    }

    
    .btn-planeja-outline {
        border: 1px solid var(--cor-media);
        color: var(--cor-media);
        font-weight: 500;
        background-color: transparent;
    }

    [data-theme="dark"] .btn-planeja-outline {
        border: 1px solid var(--cor-bege);
        color: var(--cor-bege);
    }

    .btn-planeja-outline:hover {
        background-color: var(--cor-media);
        color: white;
    }

    [data-theme="dark"] .btn-planeja-outline:hover {
        background-color: var(--cor-bege);
        color: var(--cor-escura);
    }

    
    .btn-planeja-primary {
        background-color: var(--cor-media);
        color: white;
        border: none;
        font-weight: bold;
        transition: all 0.3s ease; 
    }

    [data-theme="dark"] .btn-planeja-primary {
        background-color: var(--cor-clara);
        color: var(--cor-escura);
    }

    
    .btn-planeja-primary:hover {
        background-color: var(--cor-escura);
        color: white;
    }

    [data-theme="dark"] .btn-planeja-primary:hover {
        background-color: #ffffff;
        color: var(--cor-escura);
    }

    
    .btn-planeja-outline {
        border: 1px solid var(--cor-media);
        color: var(--cor-media);
        font-weight: 500;
        background-color: transparent;
        transition: all 0.3s ease; 
    }

    [data-theme="dark"] .btn-planeja-outline {
        border: 1px solid var(--cor-bege);
        color: var(--cor-bege);
    }

    
    .btn-planeja-outline:hover {
        background-color: var(--cor-media);
        color: white;
    }

    [data-theme="dark"] .btn-planeja-outline:hover {
        background-color: var(--cor-bege);
        color: var(--cor-escura);
    }
</style>

<div class="container mt-4">
    <div class="card-planeja shadow-sm">
        <div class="card-body p-2 p-md-4">

            <div class="d-flex align-items-center mb-4 texto-primario">
                <i class="fa-solid fa-address-card fs-3 me-3"></i>
                <h2 class="mb-0 fw-bold">Detalhes do Usuário</h2>
            </div>

            <hr class="text-muted mb-4" />

            <div class="row">
                <div class="col-md-6 mb-3">
                    <label class="fw-bold texto-primario mb-1">Nome Completo</label>
                    <p class="form-control info-box">@(Model.Funcionario?.Nome ?? "Não informado")</p>
                </div>

                <div class="col-md-6 mb-3">
                    <label class="fw-bold texto-primario mb-1">E-mail (Login)</label>
                    <p class="form-control info-box">@Model.Email</p>
                </div>

                <div class="col-md-4 mb-3">
                    <label class="fw-bold texto-primario mb-1">CPF</label>
                    <p class="form-control info-box">@(Model.Funcionario?.Cpf ?? "Não informado")</p>
                </div>

                <div class="col-md-4 mb-3">
                    <label class="fw-bold texto-primario mb-1">Cargo</label>
                    <p class="form-control info-box">@(Model.Funcionario?.Cargo ?? "Não informado")</p>
                </div>

                <div class="col-md-4 mb-3">
                    <label class="fw-bold texto-primario mb-1">Perfil de Acesso</label>
                    <p class="form-control info-box text-uppercase">
                        @if (Model.PerfilAcesso == "owner")
                        {
                            <span class="badge bg-danger">@Model.PerfilAcesso</span>
                        }
                        else if (Model.PerfilAcesso == "admin")
                        {
                            <span class="badge bg-primary">@Model.PerfilAcesso</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">@Model.PerfilAcesso</span>
                        }
                    </p>
                </div>

                <div class="col-md-12 mb-4">
                    <label class="fw-bold texto-primario mb-1">Empresa Vinculada</label>
                    <p class="form-control info-box">@Model.Empresa?.Nome</p>
                </div>
            </div>

            <div class="d-flex gap-2 mt-2">
                <a asp-action="Index" class="btn btn-planeja-outline px-4 py-2">
                    <i class="fa-solid fa-arrow-left me-2"></i> Voltar
                </a>
                <a asp-action="Editar" asp-route-id="@Model.Id" class="btn btn-planeja-primary px-4 py-2">
                    <i class="fa-solid fa-pen me-2"></i> Editar este usuário
                </a>
            </div>

        </div>
    </div>
</div>
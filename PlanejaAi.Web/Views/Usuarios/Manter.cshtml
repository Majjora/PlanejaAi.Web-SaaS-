@model PlanejaAi.Models.UsuariosViewModel
@{
    bool ehEdicao = Model != null && Model.Id > 0;
    ViewData["Title"] = ehEdicao ? "Editar Usuário" : "Novo Usuário";
}

<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

<link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
<script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>

<style>
    :root {
        --cor-escura: #213448;
        --cor-media: #547792;
        --cor-clara: #94B4C1;
        --cor-bege: #EAE0CF;
    }

    body {
        background-color: var(--cor-bege) !important;
        color: var(--cor-escura);
        transition: all 0.3s ease;
    }

    [data-theme="dark"] body {
        background-color: var(--cor-escura) !important;
        color: var(--cor-bege);
    }

    .card-planeja {
        background-color: #ffffff;
        border-radius: 12px;
        border: none;
        box-shadow: 0 8px 24px rgba(0,0,0,0.1);
        padding: 30px;
    }

    [data-theme="dark"] .card-planeja {
        background-color: var(--cor-media) !important;
    }

    .form-label {
        color: var(--cor-media);
        font-weight: 700;
        margin-bottom: 0.4rem;
    }

    [data-theme="dark"] .form-label {
        color: var(--cor-bege);
    }

    .form-control, .form-select {
        background-color: rgba(255, 255, 255, 0.8);
        border: 1px solid var(--cor-clara);
    }

    [data-theme="dark"] .form-control,
    [data-theme="dark"] .form-select {
        background-color: var(--cor-escura) !important;
        color: #ffffff !important;
        border-color: var(--cor-clara);
    }

    .main-title { color: var(--cor-media); }
    [data-theme="dark"] .main-title { color: var(--cor-bege) !important; }

    .section-title {
        color: var(--cor-media);
        font-size: 0.85rem;
        letter-spacing: 1px;
        margin-top: 2rem;
    }

    [data-theme="dark"] .section-title { color: var(--cor-bege) !important; }

    .btn-planeja-primary {
        background-color: var(--cor-media);
        color: white;
        border: none;
        font-weight: bold;
    }

    [data-theme="dark"] .btn-planeja-primary {
        background-color: var(--cor-clara);
        color: var(--cor-escura);
    }

    .btn-planeja-outline {
        border: 2px solid var(--cor-media);
        color: var(--cor-media);
        font-weight: bold;
    }

    [data-theme="dark"] .btn-planeja-outline {
        border-color: var(--cor-bege);
        color: var(--cor-bege);
    }

    
    .btn-planeja-primary, .btn-planeja-outline {
        transition: all 0.3s ease;
    }

        
        .btn-planeja-primary:hover {
            background-color: var(--cor-escura); 
            color: white;
        }

        .btn-planeja-outline:hover {
            background-color: var(--cor-media); 
            color: white;
        }

    
    [data-theme="dark"] .btn-planeja-primary:hover {
        background-color: #ffffff; 
        color: var(--cor-escura);
    }

    [data-theme="dark"] .btn-planeja-outline:hover {
        background-color: var(--cor-bege); 
        color: var(--cor-escura);
    }

    
    .select2-container .select2-selection--single {
        height: 38px; 
        background-color: rgba(255, 255, 255, 0.8);
        border: 1px solid var(--cor-clara);
        border-radius: 0.375rem;
        display: flex;
        align-items: center;
    }

    .select2-container--default .select2-selection--single .select2-selection__rendered {
        color: var(--cor-escura);
        line-height: normal;
        padding-left: 0.75rem;
    }

    .select2-container--default .select2-selection--single .select2-selection__arrow {
        height: 100%;
        right: 10px;
    }

    
    [data-theme="dark"] .select2-container .select2-selection--single {
        background-color: var(--cor-escura) !important;
        border-color: var(--cor-clara);
    }

    [data-theme="dark"] .select2-container--default .select2-selection--single .select2-selection__rendered {
        color: #ffffff !important;
    }

    [data-theme="dark"] .select2-dropdown {
        background-color: var(--cor-escura);
        border: 1px solid var(--cor-clara);
        color: #ffffff;
    }

    [data-theme="dark"] .select2-search input {
        background-color: var(--cor-media);
        color: #ffffff;
        border: 1px solid var(--cor-clara);
    }

    [data-theme="dark"] .select2-results__option--selected {
        background-color: var(--cor-media) !important;
        color: #ffffff !important;
    }

    [data-theme="dark"] .select2-results__option--highlighted.select2-results__option--selectable {
        background-color: var(--cor-clara) !important;
        color: var(--cor-escura) !important;
    }
</style>

<div class="container mt-5 mb-5">
    <div class="card-planeja">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="m-0 fw-bold main-title">
                <i class="fa-solid @(ehEdicao ? "fa-user-pen" : "fa-user-plus") me-2"></i>@ViewData["Title"]
            </h2>
        </div>

        @if (ViewBag.Erro != null)
        {
            <div class="alert alert-danger border-0 shadow-sm alert-dismissible fade show">
                @ViewBag.Erro
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        <form asp-action="@(ehEdicao ? "Editar" : "Criar")" method="post" class="needs-validation" novalidate>
            @Html.AntiForgeryToken()
            @if(ehEdicao) { <input type="hidden" asp-for="Id" /> }

            <div class="row g-3">
               
                <div class="col-md-6">
                    <label class="form-label">Nome Completo*</label>
                    <input asp-for="Nome" class="form-control" placeholder="Digite o nome" required />
                    <div class="invalid-feedback">O nome é obrigatório.</div>
                </div>

                <div class="col-md-6">
                    <label class="form-label">E-mail*</label>
                    <input asp-for="Email" type="email" class="form-control" placeholder="exemplo@email.com" required />
                    <div class="invalid-feedback">Informe um e-mail válido.</div>
                </div>

                <div class="col-md-4">
                    <label class="form-label">CPF*</label>
                    <input asp-for="Cpf" id="Cpf" class="form-control" maxlength="11" required
                           onblur="validarCpf(this.value)"
                           oninput="this.value = this.value.replace(/[^0-9]/g, '')" placeholder="Apenas números" />
                    <div class="invalid-feedback">O CPF é obrigatório (11 números).</div>
                </div>

                <div class="col-md-4">
                    <label class="form-label">Senha*</label>
                    <input asp-for="Senha" type="password" class="form-control" required="@(!ehEdicao)" />
                    <div class="invalid-feedback">A senha é obrigatória para novos usuários.</div>
                </div>

                <div class="col-md-4">
                    <label class="form-label">Cargo*</label>
                    <input asp-for="Cargo" class="form-control" placeholder="Ex: Analista" required />
                    <div class="invalid-feedback">O cargo é obrigatório.</div>
                </div>

                
                <div class="col-12">
                    <h5 class="section-title text-uppercase fw-bold">Nível de Acesso e Vínculo</h5>
                    <hr style="opacity: 0.1;" class="mt-1" />
                </div>

                
                <div class="col-md-6">
                    <label class="form-label">Perfil de Acesso*</label>
                    <select asp-for="PerfilAcesso" class="form-select" required>
                        <option value="users">User</option>
                        <option value="admin">Admin</option>

                        
                        @if (ViewBag.PerfilLogado == "owner")
                        {
                            <option value="owner">Owner</option>
                        }
                    </select>
                    <div class="invalid-feedback">Selecione um perfil.</div>
                </div>

                
                @if (ViewBag.PerfilLogado == "owner")
                {
                   @if (!ehEdicao)
                   {
                    <div class="col-md-6">
                        <label class="form-label">Empresa*</label>
                        <select asp-for="EmpresaId" class="form-select select2-empresa" required>
                            <option value="">-- Selecione a Empresa --</option>
                            @if (ViewBag.Empresas != null)
                            {
                                foreach (var emp in ViewBag.Empresas)
                                {
                                    <option value="@emp.Id">@emp.Nome</option>
                                }
                            }
                        </select>
                        <div class="invalid-feedback">Vincule o usuário a uma empresa.</div>
                    </div>
                }
                else
                {
                    <input type="hidden" asp-for="EmpresaId" />
                    }
                }
                else
                {
                    <input type="hidden" asp-for="EmpresaId" />
                }
            </div>

            <div class="mt-5 d-flex gap-2">
                <button type="submit" class="btn btn-planeja-primary px-5 py-2 shadow-sm">
                    <i class="fa-solid fa-save me-2"></i>Salvar
                </button>
                <a asp-action="Index" class="btn btn-planeja-outline px-4 py-2">
                    <i class="fa-solid fa-xmark me-2"></i>Cancelar
                </a>
            </div>
        </form>
    </div>
</div>

<script>
    (function () {
        'use strict'
        var forms = document.querySelectorAll('.needs-validation')
        Array.prototype.slice.call(forms).forEach(function (form) {
            form.addEventListener('submit', function (event) {
                if (!form.checkValidity()) {
                    event.preventDefault()
                    event.stopPropagation()
                }
                form.classList.add('was-validated')
            }, false)
        })
    })()


    
    function testarCpf(strCPF) {
        var Soma;
        var Resto;
        Soma = 0;
        if (strCPF == "00000000000" || strCPF == "11111111111" || strCPF == "22222222222" ||
            strCPF == "33333333333" || strCPF == "44444444444" || strCPF == "55555555555" ||
            strCPF == "66666666666" || strCPF == "77777777777" || strCPF == "88888888888" ||
            strCPF == "99999999999") return false;

        for (i=1; i<=9; i++) Soma = Soma + parseInt(strCPF.substring(i-1, i)) * (11 - i);
        Resto = (Soma * 10) % 11;

        if ((Resto == 10) || (Resto == 11))  Resto = 0;
        if (Resto != parseInt(strCPF.substring(9, 10)) ) return false;

        Soma = 0;
        for (i = 1; i <= 10; i++) Soma = Soma + parseInt(strCPF.substring(i-1, i)) * (12 - i);
        Resto = (Soma * 10) % 11;

        if ((Resto == 10) || (Resto == 11))  Resto = 0;
        if (Resto != parseInt(strCPF.substring(10, 11) ) ) return false;
        return true;
    }

    
    $(document).ready(function() {
        $('.select2-empresa').select2({
            width: '100%', 
            language: {
                noResults: function () {
                    return "Nenhuma empresa encontrada";
                }
            }
        });
    });
    
    function validarCpf(valor) {
        var cpf = valor.replace(/\D/g, ''); 

        
        if (cpf.length === 11) {
            const isDark = document.documentElement.getAttribute('data-theme') === 'dark';

            if (!testarCpf(cpf)) {
                
                document.getElementById('Cpf').value = '';

                Swal.fire({
                    icon: 'warning',
                    title: 'CPF Inválido',
                    text: 'O CPF informado não é válido matematicamente.',
                    background: isDark ? '#213448' : '#ffffff',
                    color: isDark ? '#EAE0CF' : '#213448',
                    confirmButtonColor: '#547792'
                });
            }
        }
    }
</script>